            <td class="cat" style="padding-left: 24px;">
              ${row.cat}
              ${row.fixed ? '<span class="fixed-label" style="display: inline-block; background: var(--surface2); border: 1px solid var(--accent); padding: 2px 8px; font-size: 10px; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; border-radius: 3px; font-weight: 500; margin-left: 8px; vertical-align: middle; line-height: 1.4;">fixed</span>' : ''}
            </td>
            <td style="text-align:right;">
              <div class="input-cell">
                <span class="currency-sym">${currencySym}</span>
                <input class="budget-input-dark" type="number" value="${row.budget}" data-id="${row.id}" data-currency="${userCurrency}" onchange="onBudgetChange('${row.id}', this, '${userCurrency}')" onblur="onBudgetChange('${row.id}', this, '${userCurrency}')" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; width: 80px; text-align: right; padding: 4px 8px; border-radius: 4px; outline: none;">
