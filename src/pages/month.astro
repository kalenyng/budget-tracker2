---
// Main budget app page
import { supabase } from '../lib/supabase';

// Prevent pre-rendering so middleware can redirect
export const prerender = false;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Budget Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/global.css">
  <script>
    (function () {
      const t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
<div class="page">

  <header>
    <div class="label">Personal finance tracker</div>
    <h1>Monthly<span> Tracker</span></h1>
    <div class="subtitle">Set budgets and track actual spending</div>
    
    <!-- Navigation -->
    <div style="margin-top: 20px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <a href="/" class="currency-btn" style="text-decoration: none; display: inline-block;">← Yearly Overview</a>
      <div style="display: flex; align-items: center; gap: 0; margin-left: 12px;">
        <button onclick="changeMonth(-1)" style="background: var(--surface2); border: 1px solid var(--border); border-right: none; color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 13px; padding: 6px 12px; cursor: pointer; border-radius: 4px 0 0 4px; transition: all 0.15s;" onmouseover="this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='var(--border)'; this.nextElementSibling.style.borderColor='var(--border)'">‹</button>
        <div id="monthDisplay" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; padding: 6px 16px; min-width: 130px; text-align: center; cursor: default;"></div>
        <button onclick="changeMonth(1)" style="background: var(--surface2); border: 1px solid var(--border); border-left: none; color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 13px; padding: 6px 12px; cursor: pointer; border-radius: 0 4px 4px 0; transition: all 0.15s;" onmouseover="this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='var(--border)'">›</button>
      </div>
      <div id="currentUserEmail" style="margin-left: auto; padding: 6px 12px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface2); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 11px; max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="Signed in user">Loading account...</div>
      <button class="currency-btn" onclick="handleSignOut()" style="color: var(--red);" title="Sign Out">Sign Out</button>
    </div>
    
  </header>

  <!-- Income Section -->
  <div class="balance-section">
    <div class="label">Monthly Income</div>
    <div id="incomeSourcesList" style="margin-top: 16px; display: flex; flex-direction: column; gap: 8px;">
      <!-- Income source rows rendered here by JS -->
    </div>
    <button onclick="addIncomeSource()" style="
      margin-top: 12px;
      background: transparent;
      border: 1px dashed var(--border);
      color: var(--text-dim);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      padding: 8px 16px;
      cursor: pointer;
      border-radius: 4px;
      width: 100%;
      transition: all 0.15s;
    " onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"
       onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'">
      + Add Income Source
    </button>
  </div>

  <!-- Balance Tracking -->
  <div class="balance-section">
    <div class="label">Account Balances</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 16px;">
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Starting Balance</label>
        <input type="number" id="zarStartBalance" placeholder="0" step="0.01" class="balance-input" onchange="updateBalance('ZAR', 'start', this.value)" onblur="updateBalance('ZAR', 'start', this.value)">
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Ending Balance</label>
        <input type="number" id="zarEndBalance" placeholder="0" step="0.01" class="balance-input" onchange="updateBalance('ZAR', 'end', this.value)" onblur="updateBalance('ZAR', 'end', this.value)">
      </div>
    </div>
    <!-- Carried Over Balance (read-only) -->
    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <label style="color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em;">
          Carried Over (from previous month)
        </label>
        <div style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--accent);" id="carriedOverDisplay">—</div>
      </div>
    </div>
  </div>

  <!-- Summary cards -->
  <div class="summary-grid" id="summaryGrid">
    <div class="summary-card">
      <div class="label">Income</div>
      <div class="val green" id="sumIncomeZar">—</div>
      <div class="note" id="sumIncomeNote">Set income above</div>
    </div>
    <div class="summary-card">
      <div class="label">Budget</div>
      <div class="val" id="sumBudgetZar">—</div>
      <div class="note" id="sumNoteZar">Set budgets below</div>
    </div>
    <div class="summary-card">
      <div class="label">Actual</div>
      <div class="val" id="sumActualZar">—</div>
      <div class="note" id="sumVarianceZar">—</div>
    </div>
    <div class="summary-card">
      <div class="label">Var</div>
      <div class="val" id="sumNetZar">—</div>
      <div class="note" id="sumNetNote">Income - Actual</div>
    </div>
  </div>

  <!-- Currency Conversion Summary -->
  <div class="balance-section" id="currencyConversionSummary" style="margin-bottom: 48px; display: none;">
    <div class="label" id="conversionLabel">Currency Conversion</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 24px; margin-top: 16px;">
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Exchange Rate</label>
        <div style="font-family: 'DM Mono', monospace; font-size: 16px; font-weight: 500; color: var(--accent);">
          <span id="exchangeRate">Loading...</span>
          <button onclick="updateExchangeRate()" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 10px; padding: 4px 8px; margin-left: 8px; cursor: pointer; border-radius: 3px; transition: all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'">Refresh</button>
        </div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Budget Total</label>
        <div id="budgetConvAmount" style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--accent);">£<span id="zarBudgetConvertedGbp">0</span></div>
        <div id="budgetBaseAmount" style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--text); margin-top: 4px;"><span id="budgetBaseSymbol">R</span><span id="zarBudgetForConversion">0</span></div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Actual Total</label>
        <div id="actualConvAmount" style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--accent);">£<span id="zarActualConvertedGbp">0</span></div>
        <div id="actualBaseAmount" style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--text); margin-top: 4px;"><span id="actualBaseSymbol">R</span><span id="zarActualForConversion">0</span></div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Net Total</label>
        <div id="netConvAmount" style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--accent);">£<span id="zarNetConvertedGbp">0</span></div>
        <div id="netBaseAmount" style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--text); margin-top: 4px;"><span id="netBaseSymbol">R</span><span id="zarNetForConversion">0</span></div>
      </div>
    </div>
  </div>

  <!-- Imported Transactions Section -->
  <div id="importedTxSection" style="display:none; margin-bottom: 48px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
      <div class="section-title" style="margin-bottom: 0;">Imported Transactions</div>
      <button id="importedTxToggleBtn" onclick="toggleImportedTx()" style="background: transparent; border: 1px solid var(--border); border-radius: 4px; color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 11px; padding: 5px 12px; cursor: pointer; transition: all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'">View Transactions</button>
    </div>
    <div id="importedTxTable" style="display:none; overflow-x: auto; border: 1px solid var(--border); border-radius: 4px;">
      <table style="width:100%; border-collapse: collapse; font-family: 'DM Mono', monospace; font-size: 12px;">
        <thead>
          <tr>
            <th style="text-align:left; padding: 8px 12px; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--border); background: var(--surface2); white-space: nowrap;">Date</th>
            <th style="text-align:left; padding: 8px 12px; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--border); background: var(--surface2);">Description</th>
            <th style="text-align:right; padding: 8px 12px; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--border); background: var(--surface2); white-space: nowrap;">Amount</th>
            <th style="text-align:left; padding: 8px 12px; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; border-bottom: 2px solid var(--border); background: var(--surface2);">Category</th>
          </tr>
        </thead>
        <tbody id="importedTxBody"></tbody>
      </table>
    </div>
  </div>

  <!-- Budget Section -->
  <div id="zarSection">
    <div class="section-title" id="budgetSectionTitle">Monthly Budget</div>
    <table class="budget-table" id="zarTable">
      <thead>
        <tr>
          <td class="cat" style="color:var(--muted);font-size:11px;letter-spacing:.1em;text-transform:uppercase">Category</td>
          <td style="text-align:right;color:var(--muted);font-size:11px;letter-spacing:.1em;text-transform:uppercase">Budget</td>
          <td style="text-align:right;color:var(--muted);font-size:11px;letter-spacing:.1em;text-transform:uppercase">Actual</td>
          <td style="text-align:right;color:var(--muted);font-size:11px;letter-spacing:.1em;text-transform:uppercase">Variance</td>
        </tr>
      </thead>
      <tbody id="zarBody"></tbody>
      <tfoot>
        <tr class="total-row" id="zarTotalRow">
          <td class="cat" style="font-weight:500">Total</td>
          <td class="budget-val" id="zarTotalBudget">—</td>
          <td class="budget-val" id="zarTotalActual">—</td>
          <td class="budget-val" id="zarTotalVariance">—</td>
        </tr>
      </tfoot>
    </table>
  </div>

  <footer>
    Budget Tracker · Set budgets and track actual spending
    <div style="margin-top: 12px;">
      <a href="/mobile-sort" style="display: inline-block; background: var(--surface2); border: 1px solid var(--accent); color: var(--accent); font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; padding: 8px 18px; border-radius: 4px; text-decoration: none; transition: background 0.15s;" onmouseover="this.style.background='var(--accent)';this.style.color='#0d0f0e'" onmouseout="this.style.background='var(--surface2)';this.style.color='var(--accent)'">⌖ Quick Sort</a>
    </div>
  </footer>

</div>

<button class="theme-toggle" onclick="toggleTheme()" id="themeToggle">☀ Light</button>

<script>
  import { supabase } from '../lib/supabase';
  import { getCurrentUser, onAuthStateChange, signOut } from '../lib/auth';
  import { formatCurrency, getCurrencySymbol, type CurrencyCode } from '../lib/currency';
  import { showToast, showConfirm, showPrompt } from '../lib/dialogs';
  import type { User } from '@supabase/supabase-js';

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = theme === 'light' ? '☾ Dark' : '☀ Light';
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }

  // Apply saved theme immediately on load
  const savedTheme = localStorage.getItem('theme') || 'dark';
  applyTheme(savedTheme);


  // Check authentication on page load
  async function checkAuth() {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = '/auth';
      return false;
    }
    updateCurrentUserEmail(user);
    return true;
  }

  function updateCurrentUserEmail(user: User | null) {
    const emailEl = document.getElementById('currentUserEmail');
    if (!emailEl) return;
    emailEl.textContent = user?.email || 'Signed in';
    emailEl.title = user?.email || 'Signed in user';
  }

  // Handle sign out
  async function handleSignOut() {
    if (await showConfirm('Sign Out', 'Are you sure you want to sign out?', 'Sign Out')) {
      await signOut();
      window.location.href = '/auth';
    }
  }

  // Type definitions
  interface CategoryData {
    id: string;
    cat: string;
    budget: number;
    actual: number;
    fixed: boolean;
    group: string | null;
  }

  interface UserSettings {
    show_currency_conversion: boolean;
    base_currency: string;
    conversion_currency: string;
  }

  interface BudgetItem {
    category_id: string;
    month: string;
    budget_amount: number;
    actual_amount: number;
    user_id?: string;
  }

  // Window interface extension
  declare global {
    interface Window {
      onBudgetChange: (categoryId: string, input: HTMLInputElement, currency: string) => Promise<void>;
      onActualChange: (categoryId: string, input: HTMLInputElement, currency: string) => Promise<void>;
      copyBudgetToActual: (categoryId: string, currency: string) => Promise<void>;
      clearActual: (categoryId: string, currency: string) => Promise<void>;
      updateBalance: (currency: string, type: string, value: string) => Promise<void>;
      addIncomeSource: () => Promise<void>;
      removeIncomeSource: (id: string) => Promise<void>;
      updateIncomeAmount: (id: string, value: string) => Promise<void>;
      updateIncomeSourceName: (id: string, value: string) => Promise<void>;
      updateExchangeRate: () => Promise<void>;
      toggleGroup: (groupName: string) => void;
      loadMonth: () => Promise<void>;
      handleSignOut: () => Promise<void>;
      changeMonth: (direction: number) => void;
      toggleImportedTx: () => void;
      onImportedTxCategoryChange: (txId: string, oldCategoryId: string | null, select: HTMLSelectElement) => Promise<void>;
    }
  }

  interface ImportedTx {
    id: string;
    date: string | null;
    description: string | null;
    amount: number;
    category_id: string | null;
    manually_edited: boolean;
  }

  let currentMonth = new Date().toISOString().slice(0, 7) + '-01';
  let zarData: CategoryData[] = [];
  let zarBudgets: number[] = [];
  let zarActuals: number[] = [];
  let incomeSources: { id: string; source_name: string; amount: number }[] = [];
  let carriedOver = 0;
  let totalIncome = 0; // sum of incomeSources amounts
  let exchangeRate = 0;
  let groupStates: Record<string, boolean> = {}; // Track collapsed/expanded state of groups
  let userCurrency: CurrencyCode = 'ZAR'; // User's preferred currency
  let userSettings: UserSettings = {
    show_currency_conversion: true,
    base_currency: 'ZAR',
    conversion_currency: 'GBP'
  };

  // Initialize
  async function init() {
    try {
      onAuthStateChange((_event, session) => {
        updateCurrentUserEmail(session?.user ?? null);
        if (!session?.user) {
          window.location.href = '/auth';
        }
      });

      // Check authentication first
      const isAuthenticated = await checkAuth();
      if (!isAuthenticated) {
        return;
      }
      
      // Load user settings first
      await loadUserSettings();
      
      // Check for month parameter in URL
      const urlParams = new URLSearchParams(window.location.search);
      const monthParam = urlParams.get('month');
      if (monthParam) {
        currentMonth = monthParam + '-01';
      }

      // Update month display
      updateMonthDisplay();

      // Test connection
      const { data: testData, error: testError } = await supabase
        .from('categories')
        .select('id, name')
        .limit(1);
      
      if (testError) {
        console.error('Connection failed:', testError.message);
        return;
      }
      
      await loadMonth();
    } catch (error) {
      console.error('Initialization error:', error);
    }
  }

  async function loadUserSettings() {
    try {
      const user = await getCurrentUser();
      if (!user) return;

      const { data: settingsRows } = await supabase
        .from('user_settings')
        .select('key, value, preferred_currency')
        .eq('user_id', user.id);

      const settingsMap = Object.fromEntries((settingsRows || []).map(s => [s.key, s.value]));
      userCurrency = (settingsRows?.[0]?.preferred_currency as CurrencyCode) || 'ZAR';
      const showConversion = settingsMap['show_currency_conversion'] === 'true';
      const conversionCurrency = (settingsMap['conversion_currency'] as CurrencyCode) || 'GBP';

      userSettings.show_currency_conversion = showConversion;
      userSettings.base_currency = userCurrency;
      userSettings.conversion_currency = conversionCurrency;

      // Update UI based on settings
      updateConversionSectionVisibility();
    } catch (error) {
      console.error('Error loading user settings:', error);
    }
  }

  function updateConversionSectionVisibility() {
    const conversionSection = document.getElementById('currencyConversionSummary');
    const conversionLabel = document.getElementById('conversionLabel');
    
    if (conversionSection && conversionLabel) {
      if (userSettings.show_currency_conversion) {
        conversionSection.style.display = 'block';
        const baseCurrency = userSettings.base_currency || 'ZAR';
        const conversionCurrency = userSettings.conversion_currency || 'GBP';
        conversionLabel.textContent = `${baseCurrency} to ${conversionCurrency} Conversion`;
        // Update currency symbols when visibility changes
        updateZarToGbpConversion();
      } else {
        conversionSection.style.display = 'none';
      }
    }
  }

  function updateCurrencyDisplay() {
    const currencySym = getCurrencySymbol(userCurrency);
    
    // Update section title
    const sectionTitleEl = document.getElementById('budgetSectionTitle');
    if (sectionTitleEl) sectionTitleEl.textContent = `Monthly Budget (${userCurrency})`;
    
    // Update balance input handlers to use current currency
    const startBalanceInput = document.getElementById('zarStartBalance') as HTMLInputElement | null;
    const endBalanceInput = document.getElementById('zarEndBalance') as HTMLInputElement | null;
    if (startBalanceInput) {
      startBalanceInput.onchange = function() { updateBalance(userCurrency, 'start', (this as HTMLInputElement).value); };
      startBalanceInput.onblur = function() { updateBalance(userCurrency, 'start', (this as HTMLInputElement).value); };
    }
    if (endBalanceInput) {
      endBalanceInput.onchange = function() { updateBalance(userCurrency, 'end', (this as HTMLInputElement).value); };
      endBalanceInput.onblur = function() { updateBalance(userCurrency, 'end', (this as HTMLInputElement).value); };
    }
    
    // Update all hardcoded currency symbols in static HTML
    const sym = getCurrencySymbol(userCurrency);

    const budgetBaseSym = document.getElementById('budgetBaseSymbol');
    if (budgetBaseSym) budgetBaseSym.textContent = sym;

    const actualBaseSym = document.getElementById('actualBaseSymbol');
    if (actualBaseSym) actualBaseSym.textContent = sym;

    const netBaseSym = document.getElementById('netBaseSymbol');
    if (netBaseSym) netBaseSym.textContent = sym;
    
    // Update all currency symbols in the table (will be done in buildZAR)
    renderIncomeSources(); // re-render with updated currency symbol
  }

  function showSkeletons() {
    // Income sources skeleton
    const incomeList = document.getElementById('incomeSourcesList');
    if (incomeList) {
      incomeList.innerHTML = `
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
      `;
    }

    // Summary cards skeleton
    const summaryGrid = document.getElementById('summaryGrid');
    if (summaryGrid) {
      summaryGrid.innerHTML = `
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 55%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 55%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 55%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 55%;"></div>
        </div>
      `;
    }

    // Budget table skeleton
    const zarBody = document.getElementById('zarBody');
    if (zarBody) {
      zarBody.innerHTML = `
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
        <tr><td colspan="4"><div class="skeleton skeleton-row" style="margin: 4px 0;"></div></td></tr>
      `;
    }
  }

  function restoreSummaryCards() {
    const summaryGrid = document.getElementById('summaryGrid');
    if (!summaryGrid) return;
    summaryGrid.innerHTML = `
      <div class="summary-card">
        <div class="label">Income</div>
        <div class="val green" id="sumIncomeZar">—</div>
        <div class="note" id="sumIncomeNote">Set income above</div>
      </div>
      <div class="summary-card">
        <div class="label">Budget</div>
        <div class="val" id="sumBudgetZar">—</div>
        <div class="note" id="sumNoteZar">Set budgets below</div>
      </div>
      <div class="summary-card">
        <div class="label">Actual</div>
        <div class="val" id="sumActualZar">—</div>
        <div class="note" id="sumVarianceZar">—</div>
      </div>
      <div class="summary-card">
        <div class="label">Var</div>
        <div class="val" id="sumNetZar">—</div>
        <div class="note" id="sumNetNote">Income - Actual</div>
      </div>
    `;
  }

  async function loadMonth() {
    showSkeletons();
    updateMonthDisplay();
    
    try {
      // Load categories (no currency filter - use user's preferred currency for display)
      const { data: zarCategories, error: catError } = await supabase
        .from('categories')
        .select('*')
        .order('category_group', { ascending: true, nullsFirst: false })
        .order('type', { ascending: false })
        .order('name', { ascending: true });

      if (catError) {
        throw new Error(`Failed to load categories: ${catError.message}`);
      }

      // Get current user first (needed for user_id in upserts)
      const { data: { user } } = await supabase.auth.getUser();

      // Load budgets with actual amounts (filtered by user_id via RLS)
      const { data: budgets, error: budgetError } = await supabase
        .from('budgets')
        .select('category_id, budget_amount, actual_amount')
        .eq('month', currentMonth);

      const budgetMap: Record<string, number> = {};
      const actualMap: Record<string, number> = {};
      
      budgets?.forEach(b => {
        budgetMap[b.category_id] = parseFloat(b.budget_amount || 0);
        actualMap[b.category_id] = parseFloat(b.actual_amount || 0);
      });

      // --- Load income sources ---
      // Get all template rows to know what sources this user has
      const { data: templates } = await supabase
        .from('incomes')
        .select('source_name')
        .eq('user_id', user?.id)
        .eq('is_template', true)
        .eq('month', '1970-01-01');

      // Ensure monthly rows exist for each template
      if (templates && templates.length > 0) {
        const upserts = templates.map(t => ({
          source_name: t.source_name,
          month: currentMonth,
          amount: 0,
          currency: userCurrency,
          is_template: false,
          user_id: user?.id
        }));
        await supabase.from('incomes').upsert(upserts, { onConflict: 'source_name,month,user_id', ignoreDuplicates: true });
      }

      // Load monthly income rows for current month
      const { data: monthlyIncomes } = await supabase
        .from('incomes')
        .select('id, source_name, amount')
        .eq('month', currentMonth)
        .eq('user_id', user?.id)
        .eq('is_template', false);

      incomeSources = (monthlyIncomes || []).map(r => ({
        id: r.id,
        source_name: r.source_name,
        amount: parseFloat(r.amount || 0)
      }));
      totalIncome = incomeSources.reduce((sum, s) => sum + s.amount, 0);

      // --- Load carried over balance ---
      const prevMonthDate = new Date(currentMonth);
      prevMonthDate.setMonth(prevMonthDate.getMonth() - 1);
      const prevMonth = prevMonthDate.toISOString().slice(0, 7) + '-01';

      const { data: prevBalance } = await supabase
        .from('monthly_balances')
        .select('ending_balance')
        .eq('month', prevMonth)
        .eq('user_id', user?.id)
        .maybeSingle();

      if (prevBalance && prevBalance.ending_balance !== null) {
        carriedOver = parseFloat(prevBalance.ending_balance || 0);
      } else {
        carriedOver = 0;
        const prevMonthName = prevMonthDate.toLocaleString('default', { month: 'long', year: 'numeric' });
        showToast(`No ending balance set for ${prevMonthName}. Carried over amount is 0.`, 'error');
      }

      // Auto-fill starting balance from previous month's ending balance
      const startBalanceInput = document.getElementById('zarStartBalance') as HTMLInputElement | null;
      if (startBalanceInput) {
        startBalanceInput.value = carriedOver > 0 ? carriedOver.toString() : '';
      }

      // Save it to monthly_balances if it differs from what's already there
      if (carriedOver > 0) {
        const { data: currentBalance } = await supabase
          .from('monthly_balances')
          .select('starting_balance')
          .eq('month', currentMonth)
          .eq('user_id', user?.id)
          .maybeSingle();

        // Only write if starting balance isn't already set
        if (!currentBalance || currentBalance.starting_balance === null) {
          await supabase.from('monthly_balances').upsert({
            month: currentMonth,
            currency: userCurrency,
            starting_balance: carriedOver,
            ending_balance: null,
            user_id: user?.id
          }, { onConflict: 'month,currency,user_id' });
        }
      }

      // Load balances (no currency filter - use user's preferred currency)
      const { data: balances, error: balancesError } = await supabase
        .from('monthly_balances')
        .select('starting_balance, ending_balance')
        .eq('month', currentMonth)
        .maybeSingle();
      
      if (balances) {
        const startBalanceInput = document.getElementById('zarStartBalance') as HTMLInputElement | null;
        const endBalanceInput = document.getElementById('zarEndBalance') as HTMLInputElement | null;
        if (startBalanceInput) startBalanceInput.value = balances.starting_balance || '';
        if (endBalanceInput) endBalanceInput.value = balances.ending_balance || '';
      }

      // Set default budgets if none exist
      const budgetsToInsert: BudgetItem[] = [];
      (zarCategories || []).forEach(cat => {
        if (!budgetMap[cat.id]) {
          const budgetAmount = cat.monthly_amount || 0;
          budgetsToInsert.push({
            category_id: cat.id,
            month: currentMonth,
            budget_amount: budgetAmount,
            actual_amount: 0,
            user_id: user?.id
          });
          budgetMap[cat.id] = budgetAmount;
        }
      });

      if (budgetsToInsert.length > 0) {
        const { error: insertError } = await supabase.from('budgets').upsert(budgetsToInsert, {
          onConflict: 'category_id,month,user_id'
        });
        if (insertError) {
          console.error('Error upserting budgets:', insertError);
        }
      }

      // Build data arrays with grouping
      zarData = (zarCategories || []).map(cat => ({
        id: cat.id,
        cat: cat.name,
        budget: budgetMap[cat.id] || 0,
        actual: actualMap[cat.id] || 0,
        fixed: cat.type === 'fixed',
        group: cat.category_group || null
      }));

      zarBudgets = zarData.map(r => r.budget);
      zarActuals = zarData.map(r => r.actual);

      // Update UI currency symbols and labels
      updateCurrencyDisplay();
      
      restoreSummaryCards();
      buildZAR();
      renderIncomeSources();
      refreshTotals();
      await loadUserSettings(); // Reload settings in case they changed
      await updateExchangeRate();
      // Load imported transactions for this month (fire-and-forget — non-blocking)
      loadImportedTransactions().catch(err => console.error('Failed to load imported transactions:', err));
    } catch (error) {
      console.error('Error loading month:', error);
    }
  }

  // ─── Imported Transactions ────────────────────────────────────────────────

  let importedTxCategories: { id: string; name: string }[] = [];
  let importedTxExpanded = false;

  async function loadImportedTransactions() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    // Reset collapsed state when month changes
    importedTxExpanded = false;
    const tableEl = document.getElementById('importedTxTable');
    const toggleBtn = document.getElementById('importedTxToggleBtn');
    if (tableEl) tableEl.style.display = 'none';
    if (toggleBtn) toggleBtn.textContent = 'View Transactions';

    const { data: rows, error } = await supabase
      .from('transactions')
      .select('id, date, description, amount, category_id, manually_edited')
      .eq('user_id', user.id)
      .eq('month', currentMonth)
      .order('date', { ascending: true });

    const section = document.getElementById('importedTxSection');
    if (!section) return;

    if (error || !rows || rows.length === 0) {
      section.style.display = 'none';
      return;
    }

    // Load categories if not yet cached
    if (importedTxCategories.length === 0) {
      const { data: cats } = await supabase
        .from('categories')
        .select('id, name')
        .order('category_group', { ascending: true, nullsFirst: false })
        .order('name', { ascending: true });
      importedTxCategories = (cats || []).map(c => ({ id: c.id as string, name: c.name as string }));
    }

    renderImportedTxTable(rows as ImportedTx[]);
    section.style.display = 'block';
  }

  function renderImportedTxTable(rows: ImportedTx[]) {
    const tbody = document.getElementById('importedTxBody');
    if (!tbody) return;

    const sym = getCurrencySymbol(userCurrency);

    const catOptions = importedTxCategories
      .map(c => `<option value="${escImportedAttr(c.id)}">${escImportedHtml(c.name)}</option>`)
      .join('');

    tbody.innerHTML = rows.map(tx => {
      const amtAbs = Math.abs(tx.amount).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      const amtStr = `${tx.amount < 0 ? '-' : ''}${sym}${amtAbs}`;
      const amtColor = tx.amount < 0 ? 'var(--red)' : 'var(--accent)';
      const editedIndicator = tx.manually_edited
        ? '<span title="Manually edited — protected from re-imports" style="color:var(--accent2);margin-left:6px;font-size:10px;">✎</span>'
        : '';

      return `
        <tr style="border-bottom: 1px solid var(--border);">
          <td style="padding: 7px 12px; color: var(--text-dim); font-size: 11px; white-space: nowrap;">${escImportedHtml(tx.date || '—')}</td>
          <td style="padding: 7px 12px; color: var(--text); max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${escImportedAttr(tx.description || '')}">${escImportedHtml(tx.description || '—')}${editedIndicator}</td>
          <td style="padding: 7px 12px; text-align: right; font-weight: 500; white-space: nowrap; color: ${amtColor};">${amtStr}</td>
          <td style="padding: 5px 12px; min-width: 150px;">
            <select
              class="balance-input"
              style="width: 100%; font-size: 11px; padding: 4px 8px;"
              onchange="onImportedTxCategoryChange('${escImportedAttr(tx.id)}', '${escImportedAttr(tx.category_id || '')}', this)"
            >
              <option value="">— Uncategorized —</option>
              ${catOptions.replace(
                `value="${escImportedAttr(tx.category_id || '')}"`,
                `value="${escImportedAttr(tx.category_id || '')}" selected`
              )}
            </select>
          </td>
        </tr>`;
    }).join('');
  }

  function toggleImportedTx() {
    importedTxExpanded = !importedTxExpanded;
    const tableEl   = document.getElementById('importedTxTable');
    const toggleBtn = document.getElementById('importedTxToggleBtn');
    if (tableEl)   tableEl.style.display   = importedTxExpanded ? 'block' : 'none';
    if (toggleBtn) toggleBtn.textContent   = importedTxExpanded ? 'Hide Transactions' : 'View Transactions';
  }

  async function onImportedTxCategoryChange(
    txId: string,
    oldCategoryId: string | null,
    select: HTMLSelectElement
  ) {
    const newCategoryId = select.value || null;
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    // Disable select during save
    select.disabled = true;

    // Step 1: Update the transaction row with new category and mark as manually edited
    const { error: updateErr } = await supabase
      .from('transactions')
      .update({ category_id: newCategoryId, manually_edited: true })
      .eq('id', txId)
      .eq('user_id', user.id);

    if (updateErr) {
      showToast('Error updating transaction: ' + updateErr.message, 'error');
      select.disabled = false;
      return;
    }

    // Step 2: Re-sum and upsert budgets for both old and new category_id
    const categoryIds = [oldCategoryId, newCategoryId].filter(Boolean) as string[];

    for (const catId of categoryIds) {
      const { data: catRows, error: sumErr } = await supabase
        .from('transactions')
        .select('amount')
        .eq('user_id', user.id)
        .eq('month', currentMonth)
        .eq('category_id', catId);

      if (sumErr) continue;

      const total = (catRows || []).reduce((s, r) => s + parseFloat(r.amount), 0);

      await supabase.from('budgets').upsert(
        {
          category_id:   catId,
          month:         currentMonth,
          actual_amount: Math.abs(total),
          user_id:       user.id,
        },
        { onConflict: 'category_id,month,user_id' }
      );
    }

    select.disabled = false;

    // Refresh the budget table to reflect the updated actuals
    await loadMonth();
  }

  function escImportedHtml(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function escImportedAttr(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function buildZAR() {
    const tbody = document.getElementById('zarBody');
    if (!tbody) return;
    tbody.innerHTML = '';
    
    if (zarData.length === 0) {
      tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:var(--text-dim);padding:24px;">No categories yet.</td></tr>`;
      return;
    }
    
    const currencySym = getCurrencySymbol(userCurrency);
    
    // Group categories by category_group
    const grouped: Record<string, CategoryData[]> = {};
    const ungrouped: CategoryData[] = [];
    
    zarData.forEach(row => {
      if (row.group) {
        if (!grouped[row.group]) {
          grouped[row.group] = [];
        }
        grouped[row.group].push(row);
      } else {
        ungrouped.push(row);
      }
    });
    
    // Sort groups and ungrouped items
    const groupKeys = Object.keys(grouped).sort();
    
    // Render grouped categories
    groupKeys.forEach(groupName => {
      const groupItems = grouped[groupName];
      const groupBudget = groupItems.reduce((sum: number, item: CategoryData) => sum + item.budget, 0);
      const groupActual = groupItems.reduce((sum: number, item: CategoryData) => sum + item.actual, 0);
      const groupVariance = groupActual - groupBudget;
      const groupVarianceClass = groupVariance > 0 ? 'over' : 'ok';
      
      // Initialize group state if not set (default to expanded)
      if (groupStates[groupName] === undefined) {
        groupStates[groupName] = true; // true = expanded, false = collapsed
      }
      const isExpanded = groupStates[groupName];
      
      // Group header row
      const groupHeader = document.createElement('tr');
      groupHeader.className = 'group-header';
      groupHeader.style.background = 'var(--surface2)';
      groupHeader.style.borderTop = '2px solid var(--border)';
      groupHeader.style.cursor = 'pointer';
