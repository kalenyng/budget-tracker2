    border: 1px solid var(--border);
    padding: 2px 8px;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-left: 6px;
    vertical-align: middle;
  }
  .tag.ok { border-color: var(--accent); color: var(--accent); }
</style>
</html>
