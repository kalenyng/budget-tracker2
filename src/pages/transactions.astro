---
// Transaction Import & Categorization page
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Transaction Import · Budget Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

<div class="page" id="mainPage">

  <!-- ── Header ──────────────────────────────────────────────────────────── -->
  <header>
    <div class="label">Personal finance tracker</div>
    <h1>Transaction<span> Import</span></h1>
    <div class="subtitle">Upload a CSV and categorize transactions with keyboard shortcuts</div>

    <div style="margin-top: 20px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <a href="/" class="currency-btn" style="text-decoration: none; display: inline-block;">← Yearly Overview</a>
      <a href="/month" class="currency-btn" style="text-decoration: none; display: inline-block;">Monthly Tracker</a>
      <a href="/mobile-sort" class="currency-btn" style="text-decoration: none; display: inline-block; color: var(--accent); border-color: var(--accent);">⌖ Quick Sort</a>
      <div
        id="currentUserEmail"
        style="margin-left: auto; padding: 6px 12px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface2); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 11px; max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
        title="Signed in user"
      >Loading account...</div>
      <button class="currency-btn" onclick="handleSignOut()" style="color: var(--red);" title="Sign Out">Sign Out</button>
    </div>
  </header>

  <!-- ── Step 1: CSV Upload ─────────────────────────────────────────────── -->
  <div class="balance-section" id="uploadSection">
    <div class="label">Step 1 — Upload CSV</div>
    <p style="color: var(--text-dim); font-size: 12px; margin-top: 8px; margin-bottom: 16px; line-height: 1.7;">
      Upload a bank transaction export in CSV format. The file needs at least a <strong style="color: var(--text);">date</strong>,
      <strong style="color: var(--text);">description</strong>, and <strong style="color: var(--text);">amount</strong> column.
      You will map which column is which in the next step.
    </p>
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <input type="file" id="csvFileInput" accept=".csv,.txt" style="display: none;">
      <button class="currency-btn" id="chooseFileBtn" style="color: var(--accent); border-color: var(--accent);">
        ↑ Choose CSV File
      </button>
      <span id="uploadStatus" style="color: var(--text-dim); font-size: 12px;">No file selected</span>
    </div>
    <div id="uploadError" style="display: none; margin-top: 12px; padding: 10px 14px; border: 1px solid var(--red); border-radius: 4px; color: var(--red); font-size: 12px; line-height: 1.5;"></div>
  </div>

  <!-- ── Step 2: Column Mapping ─────────────────────────────────────────── -->
  <div class="balance-section" id="mappingSection" style="display: none;">
    <div class="label">Step 2 — Map Columns</div>
    <p style="color: var(--text-dim); font-size: 12px; margin-top: 8px; margin-bottom: 16px; line-height: 1.7;">
      Detected <strong id="csvRowCount" style="color: var(--text);">0</strong> data rows with
      <strong id="csvColCount" style="color: var(--text);">0</strong> columns.
      Select which CSV column corresponds to each required field.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 20px;">
      <div>
        <label style="color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 6px;">Date Column</label>
        <select id="dateColSelect" class="balance-input"></select>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 6px;">Description Column</label>
        <select id="descColSelect" class="balance-input"></select>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; display: block; margin-bottom: 6px;">Amount Column</label>
        <select id="amountColSelect" class="balance-input"></select>
      </div>
    </div>

    <!-- CSV preview table -->
    <div id="previewRows" style="display: none; margin-bottom: 20px;">
      <div style="color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px;">Preview — first 3 rows</div>
      <div id="previewTable" style="overflow-x: auto; border: 1px solid var(--border); border-radius: 4px;"></div>
    </div>

    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
      <button class="currency-btn" onclick="importTransactions()" style="color: var(--accent); border-color: var(--accent);">Import Transactions →</button>
      <button class="currency-btn" onclick="resetUpload()">✕ Reset</button>
    </div>
  </div>

  <!-- ── Shortcuts + Progress ───────────────────────────────────────────── -->
  <div class="balance-section" id="shortcutsSection" style="display: none;">
    <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
      <div>
        <div class="label">Keyboard Navigation</div>
        <div style="display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap;">
          <span style="color: var(--text-dim); font-size: 12px;"><kbd>↑</kbd> <kbd>↓</kbd> &nbsp;row</span>
          <span style="color: var(--text-dim); font-size: 12px;"><kbd>←</kbd> <kbd>→</kbd> &nbsp;category</span>
          <span style="color: var(--text-dim); font-size: 12px;"><kbd>Enter</kbd> &nbsp;assign &amp; advance</span>
          <span style="color: var(--text-dim); font-size: 12px;"><kbd>Del</kbd> &nbsp;remove</span>
        </div>
        <div style="margin-top: 10px; color: var(--muted); font-size: 11px; line-height: 1.5;">
          Click anywhere outside an input field to enable keyboard navigation. The highlighted cell shows the active category for the current row.
        </div>
      </div>
      <div style="text-align: right; flex-shrink: 0;">
        <div class="label" style="text-align: right;">Progress</div>
        <div id="progressDisplay" style="color: var(--accent); font-family: 'Fraunces', serif; font-size: 32px; font-weight: 300; text-align: right; margin-top: 4px; line-height: 1;">0 / 0</div>
        <div id="progressNote" style="color: var(--text-dim); font-size: 11px; text-align: right; margin-top: 4px;">transactions categorized</div>
      </div>
    </div>
  </div>

  <!-- ── Transaction Table ──────────────────────────────────────────────── -->
  <div id="tableSection" style="display: none;">
    <div class="section-title">
      Transaction Categorization
      <span id="tableTxCount" style="font-size: 13px; margin-left: 12px; color: var(--muted); font-style: normal; font-family: 'DM Mono', monospace;"></span>
    </div>
    <div
      id="tableWrapper"
      tabindex="0"
      style="overflow: auto; max-height: 620px; border: 1px solid var(--border); border-radius: 4px; outline: none;"
    >
      <table class="tx-table" id="txTable">
        <thead id="txHead"></thead>
        <tbody id="txBody"></tbody>
        <tfoot id="txFoot"></tfoot>
      </table>
    </div>
  </div>

  <!-- ── Category Totals ────────────────────────────────────────────────── -->
  <div class="balance-section" id="totalsSection" style="display: none; margin-top: 48px;">
    <div class="label">Category Totals</div>
    <div id="totalsGrid" style="margin-top: 16px;"></div>
    <div id="uncategorizedSummary" style="display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
      <span id="uncategorizedText" style="color: var(--text-dim); font-size: 12px;"></span>
    </div>
  </div>

  <!-- ── Commit to Month Button ────────────────────────────────────────────── -->
  <div id="commitSection" style="display: none; margin-top: 48px; text-align: center;">
    <button id="commitBtn" class="commit-btn" onclick="openCommitModal()" disabled>
      Commit to Month
    </button>
  </div>

  <footer>
    Budget Tracker · Transaction Import &amp; Categorization
    <div style="margin-top: 12px;">
      <a href="/mobile-sort" style="display: inline-block; background: var(--surface2); border: 1px solid var(--accent); color: var(--accent); font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; padding: 8px 18px; border-radius: 4px; text-decoration: none; transition: background 0.15s;" onmouseover="this.style.background='var(--accent)';this.style.color='#0d0f0e'" onmouseout="this.style.background='var(--surface2)';this.style.color='var(--accent)'">⌖ Quick Sort</a>
    </div>
  </footer>
</div>

<!-- ── Commit Modal ────────────────────────────────────────────────────────── -->
<div id="commitModal" style="display:none; position:fixed; inset:0; z-index:9997; background:rgba(0,0,0,0.6); backdrop-filter:blur(2px);" onclick="closeCommitModal(event)">
  <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:32px; min-width:400px; max-width:520px; width:90%;">
    <h2 style="font-family:'Fraunces',serif; font-size:22px; font-weight:300; font-style:italic; color:var(--text); margin-bottom:24px;">Commit to Month</h2>
    <div style="margin-bottom:20px;">
      <label style="color:var(--text-dim); font-size:10px; text-transform:uppercase; letter-spacing:0.1em; display:block; margin-bottom:8px;">Select Month</label>
      <input type="month" id="commitMonthInput" class="balance-input" style="width:200px;">
    </div>
    <div id="commitSummary" style="margin-bottom:24px; padding:16px; background:var(--surface2); border:1px solid var(--border); border-radius:4px; font-size:11px; color:var(--text-dim);"></div>
    <div style="display:flex; gap:12px; justify-content:flex-end;">
      <button onclick="closeCommitModal()" class="currency-btn">Cancel</button>
      <button onclick="confirmCommit()" class="currency-btn" style="color:var(--accent); border-color:var(--accent);">Confirm Commit</button>
    </div>
  </div>
</div>

<button class="theme-toggle" onclick="toggleTheme()" id="themeToggle">☀ Light</button>

<script>
  import { supabase } from '../lib/supabase';
  import { getCurrentUser, onAuthStateChange, signOut } from '../lib/auth';
  import { getCurrencySymbol, type CurrencyCode } from '../lib/currency';
  import { showToast, showConfirm } from '../lib/dialogs';
  import type { User } from '@supabase/supabase-js';

  // ─── Types ────────────────────────────────────────────────────────────────

  interface Transaction {
    id: string;
    date: string;
    description: string;
    amount: number;
    category: string | null;
    category_id: string | null;
  }

  interface Category {
    id: string;
    name: string;
    category_group: string | null;
  }

  interface IncomeSource {
    id: string;
    name: string;
  }

  /** Unified spreadsheet column — either an expense category or an income source. */
  interface SheetColumn {
    id:    string;
    name:  string;
    type:  'expense' | 'income';
    group: string | null;
  }

  declare global {
    interface Window {
      importTransactions: () => void;
      resetUpload: () => void;
      handleSignOut: () => Promise<void>;
      toggleTheme: () => void;
      openCommitModal: () => void;
      closeCommitModal: (event?: MouseEvent) => void;
      confirmCommit: () => Promise<void>;
    }
  }

  // ─── State ────────────────────────────────────────────────────────────────

  let transactions:   Transaction[]  = [];
  let categories:     Category[]     = [];
  let incomeSources:  IncomeSource[] = [];
  let csvHeaders: string[]                   = [];
  let csvRows: Record<string, string>[]      = [];

  /** Flat ordered list of all spreadsheet columns (expense categories then income sources). */
  function allColumns(): SheetColumn[] {
    return [
      ...categories.map(c => ({ id: c.id, name: c.name, type: 'expense' as const, group: c.category_group })),
      ...incomeSources.map(s => ({ id: s.id, name: s.name, type: 'income'  as const, group: null })),
    ];
  }

  // Spreadsheet cursor
  let activeRow           = 0;
  let activeCategoryIndex = 0;  // index into allColumns()
  let activeTd: HTMLTableCellElement | null = null;

  let userCurrency: CurrencyCode = 'ZAR';

  // ─── Theme ────────────────────────────────────────────────────────────────

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = theme === 'light' ? '☾ Dark' : '☀ Light';
  }

  function toggleTheme() {
    const cur  = document.documentElement.getAttribute('data-theme') || 'dark';
    const next = cur === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }

  applyTheme(localStorage.getItem('theme') || 'dark');

  // ─── Auth ─────────────────────────────────────────────────────────────────

  async function checkAuth() {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = '/auth';
      return false;
    }
    updateCurrentUserEmail(user);
    return true;
  }

  function updateCurrentUserEmail(user: User | null) {
    const el = document.getElementById('currentUserEmail');
    if (!el) return;
    el.textContent = user?.email || 'Signed in';
    el.title       = user?.email || 'Signed in user';
  }

  async function handleSignOut() {
    if (await showConfirm('Sign Out', 'Are you sure you want to sign out?', 'Sign Out')) {
      await signOut();
      window.location.href = '/auth';
    }
  }

  // ─── Load Categories ──────────────────────────────────────────────────────

  async function loadCategories() {
    const { data, error } = await supabase
      .from('categories')
      .select('id, name, category_group')
      .order('category_group', { ascending: true, nullsFirst: false })
      .order('name', { ascending: true });

    if (error) {
      showToast('Failed to load categories: ' + error.message, 'error');
      return;
    }

    categories = (data || []).map(c => ({
      id:             c.id             as string,
      name:           c.name           as string,
      category_group: (c.category_group as string | null) || null,
    }));
  }

  // ─── Load Income Sources ──────────────────────────────────────────────────

  async function loadIncomeSources() {
    const { data, error } = await supabase
      .from('incomes')
      .select('id, source_name')
      .eq('is_template', true)
      .order('source_name', { ascending: true });

    if (error) {
      showToast('Failed to load income sources: ' + error.message, 'error');
      return;
    }

    incomeSources = (data || []).map(s => ({
      id:   s.id          as string,
      name: s.source_name as string,
    }));
  }

  // ─── CSV Parsing (no external dependency) ────────────────────────────────

  /**
   * Parse a single CSV line, respecting quoted fields (including quoted commas
   * and escaped double-quotes per RFC 4180).
   */
  function parseCSVLine(line: string): string[] {
    const result: string[] = [];
    let current  = '';
    let inQuotes = false;

    for (let i = 0; i < line.length; i++) {
      const ch   = line[i];
      const next = line[i + 1];

      if (ch === '"') {
        if (inQuotes && next === '"') { current += '"'; i++; } // escaped quote
        else { inQuotes = !inQuotes; }
      } else if (ch === ',' && !inQuotes) {
        result.push(current.trim());
        current = '';
      } else {
        current += ch;
      }
    }

    result.push(current.trim());
    return result;
  }

  /**
   * Read a File as text then parse it as CSV.
   * Returns headers (first row) and rows (remaining rows as header-keyed objects).
   */
  function parseCSVFile(
    file: File
  ): Promise<{ headers: string[]; rows: Record<string, string>[] }> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();

      reader.onload = (e) => {
        try {
          const text  = (e.target as FileReader).result as string;
          // Normalise line endings then split
          const lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');

          // Find first non-empty line as the header
          const headerLine = lines.find(l => l.trim());
          if (!headerLine) { reject(new Error('File is empty')); return; }

          const headers   = parseCSVLine(headerLine);
          const headerIdx = lines.indexOf(headerLine);

          const rows: Record<string, string>[] = [];
          for (let i = headerIdx + 1; i < lines.length; i++) {
            const line = lines[i];
            if (!line.trim()) continue; // skip blank lines

            const values = parseCSVLine(line);
            // Skip rows that are entirely empty
            if (values.every(v => v === '')) continue;

            const row: Record<string, string> = {};
            headers.forEach((h, hi) => { row[h] = values[hi] ?? ''; });
            rows.push(row);
          }

          resolve({ headers, rows });
        } catch (err: any) {
          reject(err);
        }
      };

      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsText(file);
    });
  }

  // ─── File Upload ──────────────────────────────────────────────────────────

  async function handleFileChange(event: Event) {
    const input = event.target as HTMLInputElement;
    const file  = input.files?.[0];
    if (!file) return;

    const statusEl = document.getElementById('uploadStatus');
    const errorEl  = document.getElementById('uploadError');
    if (statusEl) statusEl.textContent = `Parsing "${file.name}"…`;
    if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

    try {
      const { headers, rows } = await parseCSVFile(file);

      if (headers.length === 0) {
        showFieldError(errorEl, 'Could not detect column headers. Make sure your CSV has a header row.');
        if (statusEl) statusEl.textContent = 'No file selected';
        return;
      }
      if (rows.length === 0) {
        showFieldError(errorEl, 'The CSV file appears to be empty after the header row.');
        if (statusEl) statusEl.textContent = 'No file selected';
        return;
      }

      csvHeaders = headers;
      csvRows    = rows;

      if (statusEl) statusEl.textContent = `✓ "${file.name}" — ${rows.length} rows, ${headers.length} columns`;

      populateMappingDropdowns();
      renderPreview();

      const rowCountEl = document.getElementById('csvRowCount');
      const colCountEl = document.getElementById('csvColCount');
      if (rowCountEl) rowCountEl.textContent = rows.length.toString();
      if (colCountEl) colCountEl.textContent = headers.length.toString();

      const mappingSection = document.getElementById('mappingSection');
      if (mappingSection) {
        mappingSection.style.display = 'block';
        mappingSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    } catch (err: any) {
      showFieldError(errorEl, `Could not parse CSV: ${err.message}`);
      if (statusEl) statusEl.textContent = 'No file selected';
    }
  }

  function showFieldError(el: HTMLElement | null, msg: string) {
    if (!el) return;
    el.textContent    = msg;
    el.style.display  = 'block';
  }

  // ─── Column Mapping ───────────────────────────────────────────────────────

  function populateMappingDropdowns() {
    const ids    = ['dateColSelect', 'descColSelect', 'amountColSelect'] as const;
    const selects = ids.map(id => document.getElementById(id) as HTMLSelectElement | null);
    if (selects.some(s => !s)) return;

    const optHtml = csvHeaders
      .map(h => `<option value="${escAttr(h)}">${escHtml(h)}</option>`)
      .join('');
    selects.forEach(s => { if (s) s.innerHTML = optHtml; });

    // Auto-detect by fuzzy matching
    const lower = csvHeaders.map(h => h.toLowerCase());
    const pick  = (re: RegExp) => lower.findIndex(h => re.test(h));

    const dateIdx = pick(/\bdate\b|datum|txdate|valuedate|transaction[_\s]?date/);
    const descIdx = pick(/\bdescr?|narr|detail|memo|\bpayee\b|particulars|reference/);
    const amtIdx  = pick(/\bamount\b|\bamt\b|\bdebit\b|\bcredit\b|\bvalue\b/);

    const [dateSel, descSel, amtSel] = selects;
    if (dateIdx >= 0 && dateSel) dateSel.selectedIndex = dateIdx;
    if (descIdx >= 0 && descSel) descSel.selectedIndex = descIdx;
    if (amtIdx  >= 0 && amtSel)  amtSel.selectedIndex  = amtIdx;
  }

  function renderPreview() {
    const container = document.getElementById('previewRows');
    const tableEl   = document.getElementById('previewTable');
    if (!container || !tableEl) return;

    const preview = csvRows.slice(0, 3);
    if (preview.length === 0) { container.style.display = 'none'; return; }

    let html = '<table style="width:100%;border-collapse:collapse;font-size:11px;">';
    // Header
    html += '<tr>';
    csvHeaders.forEach(h => {
      html += `<th style="text-align:left;padding:6px 10px;color:var(--muted);border-bottom:1px solid var(--border);font-weight:500;white-space:nowrap;">${escHtml(h)}</th>`;
    });
    html += '</tr>';
    // Rows
    preview.forEach(row => {
      html += '<tr>';
      csvHeaders.forEach(h => {
        const val = String(row[h] ?? '').slice(0, 50);
        html += `<td style="padding:5px 10px;color:var(--text-dim);border-bottom:1px solid var(--border);white-space:nowrap;">${escHtml(val)}</td>`;
      });
      html += '</tr>';
    });
    html += '</table>';

    tableEl.innerHTML    = html;
    container.style.display = 'block';
  }

  // ─── Import ───────────────────────────────────────────────────────────────

  function importTransactions() {
    const dateCol   = (document.getElementById('dateColSelect')   as HTMLSelectElement)?.value;
    const descCol   = (document.getElementById('descColSelect')   as HTMLSelectElement)?.value;
    const amountCol = (document.getElementById('amountColSelect') as HTMLSelectElement)?.value;

    if (!dateCol || !descCol || !amountCol) {
      showToast('Please map all three columns before importing.', 'error');
      return;
    }

    const parsed: Transaction[] = [];
    let skipped = 0;

    csvRows.forEach((row, i) => {
      const dateRaw   = String(row[dateCol]   ?? '').trim();
      const desc      = String(row[descCol]   ?? '').trim();
      const amountRaw = String(row[amountCol] ?? '').trim();

      // Skip completely empty rows
      if (!dateRaw && !desc && !amountRaw) return;

      const date   = normalizeDate(dateRaw);
      const amount = parseAmount(amountRaw);

      if (date === null || amount === null) {
        skipped++;
        return;
      }

      parsed.push({
        id:          `tx-${i}-${Date.now()}`,
        date,
        description: desc || '(no description)',
        amount,
        category:    null,
        category_id: null,
      });
    });

    if (parsed.length === 0) {
      showToast('No valid transactions found. Check your column mapping and try again.', 'error');
      return;
    }

    transactions        = parsed;
    activeRow           = 0;
    activeCategoryIndex = 0;
    activeTd            = null;

    const msg = skipped > 0
      ? `Imported ${parsed.length} transactions (${skipped} row${skipped !== 1 ? 's' : ''} skipped).`
      : `Imported ${parsed.length} transactions.`;
    showToast(msg, 'success');

    // Render table
    renderTable();

    // Show dependent sections
    ['tableSection', 'shortcutsSection', 'totalsSection', 'commitSection'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'block';
    });

    const countEl = document.getElementById('tableTxCount');
    if (countEl) countEl.textContent = `${parsed.length} transactions`;

    updateProgress();
    renderTotals();
    checkCommitReady();

    // Set initial active cell and focus the table so keyboard events work immediately
    setTimeout(() => {
      setActiveCell(0, 0);
      const wrapper = document.getElementById('tableWrapper');
      if (wrapper) wrapper.focus();
      wrapper?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 50);
  }

  function resetUpload() {
    csvHeaders   = [];
    csvRows      = [];
    transactions = [];
    activeTd     = null;

    const fileInput = document.getElementById('csvFileInput') as HTMLInputElement;
    if (fileInput) fileInput.value = '';

    const statusEl = document.getElementById('uploadStatus');
    if (statusEl) statusEl.textContent = 'No file selected';

    const errorEl = document.getElementById('uploadError');
    if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }

    ['mappingSection', 'tableSection', 'shortcutsSection', 'totalsSection', 'commitSection'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });
  }

  // ─── Parsing Helpers ──────────────────────────────────────────────────────

  function normalizeDate(raw: string): string | null {
    if (!raw) return null;

    const pats: [RegExp, (m: RegExpMatchArray) => string][] = [
      [/^(\d{2})\/(\d{2})\/(\d{4})$/, m => `${m[3]}-${m[2]}-${m[1]}`],  // DD/MM/YYYY
      [/^(\d{4})-(\d{2})-(\d{2})$/,   m => `${m[1]}-${m[2]}-${m[3]}`],  // YYYY-MM-DD
      [/^(\d{2})-(\d{2})-(\d{4})$/,   m => `${m[3]}-${m[2]}-${m[1]}`],  // DD-MM-YYYY
    ];

    for (const [re, fn] of pats) {
      const m = raw.match(re);
      if (m) return fn(m);
    }

    // Fallback to native Date parsing
    const d = new Date(raw);
    if (!isNaN(d.getTime())) return d.toISOString().slice(0, 10);
    return null;
  }

  function parseAmount(raw: string): number | null {
    if (!raw) return null;
    // Remove currency symbols, spaces, commas — keep minus sign and decimal
    let s   = raw.replace(/[R$£€,\s]/g, '').trim();
    const neg = s.startsWith('-') || /dr$/i.test(s);
    s = s.replace(/^-/, '').replace(/dr$/i, '');
    const n = parseFloat(s);
    if (isNaN(n)) return null;
    return neg ? -n : n;
  }

  // ─── Table Rendering ──────────────────────────────────────────────────────

  /** Format an amount using the user's currency symbol and 2 decimal places. */
  function fmtAmt(amount: number): string {
    const sym = getCurrencySymbol(userCurrency);
    const abs = Math.abs(amount).toLocaleString(undefined, {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    });
    return `${amount < 0 ? '-' : ''}${sym}${abs}`;
  }

  /**
   * Build the full table HTML from scratch.
   * Uses string concatenation for performance with 500+ rows.
   * Only called once after import; subsequent updates modify cells in-place.
   */
  function renderTable() {
    const head = document.getElementById('txHead');
    const body = document.getElementById('txBody');
    const foot = document.getElementById('txFoot');
    if (!head || !body || !foot) return;

    const cols = allColumns();

    // ── Header row ──
    let h = '<tr>';
    h += '<th class="col-date">Date</th>';
    h += '<th class="col-desc">Description</th>';
    h += '<th class="col-amt">Amount</th>';
    cols.forEach((col, ci) => {
      // Visual separator before the first income column
      const isFirstIncome = col.type === 'income' && (ci === 0 || cols[ci - 1].type !== 'income');
      const sepClass = isFirstIncome ? ' col-income-sep' : '';
      const cls = col.type === 'income' ? `col-cat col-income${sepClass}` : `col-cat${sepClass}`;
      const title = col.group ? `${col.name} · ${col.group}` : col.name;
      h += `<th class="${cls}" title="${escAttr(title)}">${escHtml(col.name)}</th>`;
    });
    h += '</tr>';
    head.innerHTML = h;

    // ── Body — built as one large string for performance ──
    const parts: string[] = [];
    transactions.forEach((tx, ri) => {
      const amtCls = tx.amount < 0 ? 'tx-neg' : 'tx-pos';
      let row = `<tr data-row="${ri}">`;
      row += `<td class="col-date">${escHtml(tx.date)}</td>`;
      row += `<td class="col-desc" title="${escAttr(tx.description)}">${escHtml(tx.description)}</td>`;
      row += `<td class="col-amt ${amtCls}">${escHtml(fmtAmt(tx.amount))}</td>`;
      cols.forEach((col, ci) => {
        const assigned = tx.category === col.name;
        const isFirstIncome = col.type === 'income' && (ci === 0 || cols[ci - 1].type !== 'income');
        const sepClass = isFirstIncome ? ' col-income-sep' : '';
        row += `<td class="cat-cell${sepClass}" data-row="${ri}" data-cat="${ci}">${assigned ? escHtml(fmtAmt(tx.amount)) : ''}</td>`;
      });
      row += '</tr>';
      parts.push(row);
    });
    body.innerHTML = parts.join('');

    // ── Footer totals row ──
    let f = '<tr class="tx-totals-row">';
    f += '<td class="col-date" colspan="2">Totals</td>';
    f += '<td class="col-amt"></td>';
    cols.forEach((col, ci) => {
      const isFirstIncome = col.type === 'income' && (ci === 0 || cols[ci - 1].type !== 'income');
      const sepClass = isFirstIncome ? ' col-income-sep' : '';
      f += `<td class="cat-cell cat-total${sepClass}" id="foot-total-${ci}">—</td>`;
    });
    f += '</tr>';
    foot.innerHTML = f;

    // ── Click-to-select: event delegation on tbody ──
    body.addEventListener('click', (e: MouseEvent) => {
      const td = (e.target as HTMLElement).closest<HTMLTableCellElement>('td.cat-cell');
      if (!td) return;
      const row = parseInt(td.dataset.row ?? '-1', 10);
      const cat = parseInt(td.dataset.cat  ?? '-1', 10);
      if (row >= 0 && cat >= 0) {
        setActiveCell(row, cat);
        const wrapper = document.getElementById('tableWrapper');
        if (wrapper) wrapper.focus();
      }
    });
  }

  // ─── Active Cell ──────────────────────────────────────────────────────────

  /**
   * Move the spreadsheet cursor to (row, cat), clamping to valid bounds.
   * Only touches two DOM elements: old active cell and new active cell.
   */
  function setActiveCell(row: number, cat: number) {
    if (activeTd) activeTd.classList.remove('active-cell');

    activeRow           = Math.max(0, Math.min(row, transactions.length - 1));
    activeCategoryIndex = Math.max(0, Math.min(cat, allColumns().length - 1));

    activeTd = document.querySelector<HTMLTableCellElement>(
      `td.cat-cell[data-row="${activeRow}"][data-cat="${activeCategoryIndex}"]`
    );

    if (activeTd) {
      activeTd.classList.add('active-cell');
      activeTd.scrollIntoView({ block: 'nearest', inline: 'nearest' });
    }
  }

  // ─── Category Assignment ──────────────────────────────────────────────────

  /** Assign the active column to the active transaction and advance one row. */
  function assignCategory() {
    const cols = allColumns();
    if (!transactions.length || !cols.length) return;

    const tx          = transactions[activeRow];
    const cat         = cols[activeCategoryIndex];
    const prevCategory = tx.category;

    tx.category    = cat.name;
    tx.category_id = cat.id;

    // Update only the cat-cells in this single row — no full re-render
    const rowEl = document.querySelector<HTMLTableRowElement>(`tr[data-row="${activeRow}"]`);
    if (rowEl) {
      rowEl.querySelectorAll<HTMLTableCellElement>('.cat-cell').forEach((td, ci) => {
        td.textContent = ci === activeCategoryIndex ? fmtAmt(tx.amount) : '';
      });
    }

    // Update footer totals only for the affected categories
    if (prevCategory && prevCategory !== cat.name) updateSingleFootTotal(prevCategory);
    updateSingleFootTotal(cat.name);

    updateProgress();
    renderTotals();
    checkCommitReady();

    // Advance to next row
    if (activeRow < transactions.length - 1) {
      setActiveCell(activeRow + 1, activeCategoryIndex);
    }
  }

  /** Remove the category from the active transaction. */
  function removeCategory() {
    if (!transactions.length) return;

    const tx = transactions[activeRow];
    const old = tx.category;
    if (!old) return;

    tx.category    = null;
    tx.category_id = null;

    const rowEl = document.querySelector<HTMLTableRowElement>(`tr[data-row="${activeRow}"]`);
    if (rowEl) {
      rowEl.querySelectorAll<HTMLTableCellElement>('.cat-cell').forEach(td => {
        td.textContent = '';
      });
    }

    updateSingleFootTotal(old);
    updateProgress();
    renderTotals();
    checkCommitReady();
  }

  /** Recompute and update one column's footer total. */
  function updateSingleFootTotal(catName: string) {
    const ci = allColumns().findIndex(c => c.name === catName);
    if (ci < 0) return;

    const total = transactions
      .filter(tx => tx.category === catName)
      .reduce((sum, tx) => sum + tx.amount, 0);

    const el = document.getElementById(`foot-total-${ci}`);
    if (el) {
      el.textContent = total !== 0 ? fmtAmt(total) : '—';
      el.className   = 'cat-cell cat-total ' + (total < 0 ? 'tx-neg' : total > 0 ? 'tx-pos' : '');
    }
  }

  // ─── Keyboard Navigation ──────────────────────────────────────────────────

  function initKeyboard() {
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      // Only handle when table section is visible
      const tableSection = document.getElementById('tableSection');
      if (!tableSection || tableSection.style.display === 'none') return;

      // Don't intercept while user is typing in an input
      const tag = (document.activeElement as HTMLElement)?.tagName?.toLowerCase() ?? '';
      if (tag === 'input' || tag === 'select' || tag === 'textarea') return;

      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          setActiveCell(activeRow + 1, activeCategoryIndex);
          break;
        case 'ArrowUp':
          e.preventDefault();
          setActiveCell(activeRow - 1, activeCategoryIndex);
          break;
        case 'ArrowRight':
          e.preventDefault();
          setActiveCell(activeRow, activeCategoryIndex + 1);
          break;
        case 'ArrowLeft':
          e.preventDefault();
          setActiveCell(activeRow, activeCategoryIndex - 1);
          break;
        case 'Enter':
          e.preventDefault();
          assignCategory();
          break;
        case 'Delete':
          e.preventDefault();
          removeCategory();
          break;
        case 'Backspace': {
          // Only intercept Backspace when the table wrapper has focus (not a text input)
          const wrapper = document.getElementById('tableWrapper');
          if (document.activeElement === wrapper) {
            e.preventDefault();
            removeCategory();
          }
          break;
        }
      }
    });
  }

  // ─── Totals ───────────────────────────────────────────────────────────────

  /** Render the category + income-source totals card grid below the table. */
  function renderTotals() {
    const grid = document.getElementById('totalsGrid');
    if (!grid) return;

    const cols   = allColumns();
    const totals = cols.map(col =>
      transactions
        .filter(tx => tx.category === col.name)
        .reduce((sum, tx) => sum + tx.amount, 0)
    );

    const hasAny = totals.some(t => t !== 0);

    if (!hasAny) {
      grid.innerHTML = '<div style="color: var(--text-dim); font-size: 12px; line-height: 1.6;">No columns assigned yet. Use arrow keys to navigate the table and press <kbd style="display:inline-block;background:var(--surface2);border:1px solid var(--border);border-radius:3px;padding:1px 5px;font-size:11px;">Enter</kbd> to assign.</div>';
    } else {
      // Group cards: expenses first, then income sources
      const renderGroup = (type: 'expense' | 'income') => {
        let html = '';
        cols.forEach((col, i) => {
          if (col.type !== type) return;
          const total = totals[i];
          if (total === 0) return;
          // Expenses: red if positive (overspent), accent if negative spend
          // Income sources: always accent (money in)
          const color   = type === 'income'
            ? 'var(--accent)'
            : (total < 0 ? 'var(--red)' : 'var(--accent)');
          const txCount = transactions.filter(tx => tx.category === col.name).length;
          const badge   = type === 'income'
            ? `<div style="display:inline-block;background:color-mix(in srgb,var(--accent2) 15%,transparent);border:1px solid var(--accent2);color:var(--accent2);font-size:9px;letter-spacing:.08em;text-transform:uppercase;padding:1px 5px;border-radius:3px;margin-bottom:6px;">income</div>`
            : '';
          html += `
            <div style="border: 1px solid var(--border); border-radius: 4px; padding: 14px; background: var(--surface);">
              ${badge}
              <div style="color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${escAttr(col.name)}">${escHtml(col.name)}</div>
              <div style="font-family: 'Fraunces', serif; font-size: 22px; font-weight: 300; color: ${color}; line-height: 1.1;">${escHtml(fmtAmt(total))}</div>
              <div style="color: var(--muted); font-size: 10px; margin-top: 4px;">${txCount} transaction${txCount !== 1 ? 's' : ''}</div>
              ${col.group ? `<div style="color: var(--muted); font-size: 10px; margin-top: 2px; font-style: italic;">${escHtml(col.group)}</div>` : ''}
            </div>`;
        });
        return html;
      };

      const expHtml = renderGroup('expense');
      const incHtml = renderGroup('income');

      let html = '';
      if (expHtml) {
        html += '<div style="color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">Expenses</div>';
        html += `<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; margin-bottom: 24px;">${expHtml}</div>`;
      }
      if (incHtml) {
        html += '<div style="color:var(--accent2);font-size:10px;text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">Income Sources</div>';
        html += `<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px;">${incHtml}</div>`;
      }
      grid.innerHTML = html;
    }

    // Uncategorized summary
    const uncatTxs   = transactions.filter(tx => tx.category === null);
    const uncatAmt   = uncatTxs.reduce((s, tx) => s + tx.amount, 0);
    const uncatEl    = document.getElementById('uncategorizedSummary');
    const uncatTextEl = document.getElementById('uncategorizedText');
    if (uncatEl && uncatTextEl) {
      if (uncatTxs.length > 0) {
        uncatTextEl.textContent = `${uncatTxs.length} uncategorized transaction${uncatTxs.length !== 1 ? 's' : ''} · total ${fmtAmt(uncatAmt)}`;
        uncatEl.style.display   = 'block';
      } else {
        uncatEl.style.display = 'none';
      }
    }
  }

  /** Update the progress counter. */
  function updateProgress() {
    const categorized = transactions.filter(tx => tx.category !== null).length;
    const total       = transactions.length;
    const remaining   = total - categorized;

    const progEl = document.getElementById('progressDisplay');
    const noteEl = document.getElementById('progressNote');
    if (progEl) progEl.textContent = `${categorized} / ${total}`;
    if (noteEl) noteEl.textContent = `transactions categorized (${remaining} remaining)`;
  }

  // ─── Utilities ────────────────────────────────────────────────────────────

  function escHtml(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function escAttr(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  // ─── Commit to Month ──────────────────────────────────────────────────────

  /** Enable the Commit button only when every transaction has a category_id. */
  function checkCommitReady() {
    const btn = document.getElementById('commitBtn') as HTMLButtonElement | null;
    if (!btn) return;
    const allCategorised = transactions.length > 0 &&
      transactions.every(tx => tx.category_id !== null);
    btn.disabled = !allCategorised;
  }

  /** Build and display the per-category commit summary inside the modal. */
  function buildCommitSummary() {
    const summaryEl = document.getElementById('commitSummary');
    if (!summaryEl) return;

    const expenseCategoryIds = new Set(categories.map(c => c.id));
    const grouped: Record<string, number> = {};

    transactions.forEach(tx => {
      if (!tx.category_id) return;
      if (!expenseCategoryIds.has(tx.category_id)) return; // skip income sources
      grouped[tx.category_id] = (grouped[tx.category_id] || 0) + tx.amount;
    });

    const entries = Object.entries(grouped);
    if (entries.length === 0) {
      summaryEl.textContent = 'No expense categories to commit.';
      return;
    }

    let html = '<div style="display:flex; flex-direction:column; gap:8px;">';
    entries.forEach(([catId, total]) => {
      const cat  = categories.find(c => c.id === catId);
      const name = cat?.name ?? catId;
      const color = total < 0 ? 'var(--red)' : 'var(--accent)';
      html += `<div style="display:flex; justify-content:space-between; align-items:center;">`;
      html += `<span>${escHtml(name)}</span>`;
      html += `<span style="font-family:'DM Mono',monospace; color:${color};">${escHtml(fmtAmt(total))}</span>`;
      html += `</div>`;
    });
    html += '</div>';
    summaryEl.innerHTML = html;
  }

  /** Open the commit modal, defaulting to the current calendar month. */
  function openCommitModal() {
    const now   = new Date();
    const month = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
    const input = document.getElementById('commitMonthInput') as HTMLInputElement | null;
    if (input) input.value = month;

    buildCommitSummary();

    const modal = document.getElementById('commitModal');
    if (modal) modal.style.display = 'block';
  }

  /** Close on backdrop click or cancel button press. */
  function closeCommitModal(event?: MouseEvent) {
    if (event && (event.target as HTMLElement).id !== 'commitModal') return;
    const modal = document.getElementById('commitModal');
    if (modal) modal.style.display = 'none';
  }

  /** Upsert individual transactions then re-sum actuals into the budgets table. */
  async function confirmCommit() {
    const input = document.getElementById('commitMonthInput') as HTMLInputElement | null;
    const selectedMonth = input?.value;
    if (!selectedMonth) {
      showToast('Please select a month.', 'error');
      return;
    }

    const user = await getCurrentUser();
    if (!user) {
      showToast('Not authenticated.', 'error');
      return;
    }

    const monthDate = `${selectedMonth}-01`;
    const expenseCategoryIds = new Set(categories.map(c => c.id));

    // Only commit transactions that have an expense category_id
    const toCommit = transactions.filter(
      tx => tx.category_id && expenseCategoryIds.has(tx.category_id)
    );

    if (toCommit.length === 0) {
      showToast('No expense categories to commit.', 'error');
      return;
    }

    // Step 1: Fetch existing rows that the user has manually edited — protect them
    const { data: manualRows, error: fetchErr } = await supabase
      .from('transactions')
      .select('date, description, amount')
      .eq('user_id', user.id)
      .eq('month', monthDate)
      .eq('manually_edited', true);

    if (fetchErr) {
      showToast('Error checking existing transactions: ' + fetchErr.message, 'error');
      return;
    }

    // Build a Set of natural keys for manually-edited rows
    const protectedKeys = new Set(
      (manualRows || []).map(r => `${r.date}||${r.description}||${r.amount}`)
    );

    // Step 2: Filter out any incoming transaction that matches a protected natural key
    const upsertPayload = toCommit
      .filter(tx => !protectedKeys.has(`${tx.date}||${tx.description}||${tx.amount}`))
      .map(tx => ({
        user_id:     user.id,
        month:       monthDate,
        date:        tx.date,
        description: tx.description,
        amount:      tx.amount,
        category_id: tx.category_id,
        manually_edited: false,
      }));

    // Step 3: Upsert on natural key — updates category_id on re-import
    if (upsertPayload.length > 0) {
      const { error: upsertErr } = await supabase
        .from('transactions')
        .upsert(upsertPayload, {
          onConflict: 'user_id,month,date,description,amount',
          ignoreDuplicates: false,
        });

      if (upsertErr) {
        showToast('Error saving transactions: ' + upsertErr.message, 'error');
        return;
      }
    }

    // Step 4: Re-sum all rows for this user+month (including manually-edited ones) and upsert budgets
    const { data: allRows, error: allErr } = await supabase
      .from('transactions')
      .select('category_id, amount')
      .eq('user_id', user.id)
      .eq('month', monthDate)
      .not('category_id', 'is', null);

    if (allErr) {
      showToast('Error reading transaction totals: ' + allErr.message, 'error');
      return;
    }

    const grouped: Record<string, number> = {};
    (allRows || []).forEach(row => {
      if (!row.category_id || !expenseCategoryIds.has(row.category_id)) return;
      grouped[row.category_id] = (grouped[row.category_id] || 0) + parseFloat(row.amount);
    });

    const budgetRows = Object.entries(grouped).map(([catId, total]) => ({
      category_id:   catId,
      month:         monthDate,
      actual_amount: Math.abs(total),
      user_id:       user.id,
    }));

    if (budgetRows.length > 0) {
      const { error: budgetErr } = await supabase
        .from('budgets')
        .upsert(budgetRows, { onConflict: 'category_id,month,user_id' });

      if (budgetErr) {
        showToast('Error committing actuals: ' + budgetErr.message, 'error');
        return;
      }
    }

    // Format month name for toast: e.g. "March 2026"
    const [yr, mo] = selectedMonth.split('-');
    const monthName = new Date(parseInt(yr), parseInt(mo) - 1, 1)
      .toLocaleString('default', { month: 'long', year: 'numeric' });

    showToast(`Actuals committed to ${monthName}`, 'success');

    const modal = document.getElementById('commitModal');
    if (modal) modal.style.display = 'none';
  }

  // ─── Init ─────────────────────────────────────────────────────────────────

  async function init() {
    try {
      // Auth state listener — redirect immediately if session expires
      onAuthStateChange((_event, session) => {
        updateCurrentUserEmail(session?.user ?? null);
        if (!session?.user) window.location.href = '/auth';
      });

      // Check auth before loading any data
      const isAuthenticated = await checkAuth();
      if (!isAuthenticated) return;

      // Load user preferred currency
      const user = await getCurrentUser();
      if (user) {
        const { data: settings } = await supabase
          .from('user_settings')
          .select('value')
          .eq('user_id', user.id)
          .eq('key', 'preferred_currency')
          .maybeSingle();
        if (settings?.value) {
          userCurrency = settings.value as CurrencyCode;
        }
      }

      // Load categories and income sources from Supabase
      await loadCategories();
      await loadIncomeSources();

      // Set up keyboard navigation listener
      initKeyboard();

      // Attach file input handler via JS (no global needed)
      const fileInput = document.getElementById('csvFileInput') as HTMLInputElement;
      if (fileInput) fileInput.addEventListener('change', handleFileChange);

      const chooseBtn = document.getElementById('chooseFileBtn');
      if (chooseBtn && fileInput) {
        chooseBtn.addEventListener('click', () => fileInput.click());
      }

    } catch (err) {
      console.error('Initialization error:', err);
    }
  }

  // Expose functions used in onclick="" attributes in the HTML template
  window.importTransactions = importTransactions;
  window.resetUpload        = resetUpload;
  window.handleSignOut      = handleSignOut;
  window.toggleTheme        = toggleTheme;
  window.openCommitModal    = openCommitModal;
  window.closeCommitModal   = closeCommitModal;
  window.confirmCommit      = confirmCommit;

  // Kick off initialization
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  /* ── Page overrides ─────────────────────────────────────────────────────── */

  h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  h1 span { color: var(--accent); }

  kbd {
    display: inline-block;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 5px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text);
  }

  /* ── Transaction table ───────────────────────────────────────────────────── */

  .tx-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
  }

  /* Sticky column headers — stay visible while scrolling */
  .tx-table th {
