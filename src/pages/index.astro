      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="cat">
          ${row.cat}
          ${row.fixed ? '<span class="fixed-label" style="display: inline-block; background: var(--surface2); border: 1px solid var(--accent); padding: 2px 8px; font-size: 10px; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; border-radius: 3px; font-weight: 500; margin-left: 8px; vertical-align: middle; line-height: 1.4;">fixed</span>' : ''}
        </td>
        <td style="text-align:right;">
          <div class="input-cell">
            <span class="currency-sym">${currencySym}</span>
            <input class="budget-input-dark" type="number" value="${row.budget}" data-id="${row.id}" data-currency="${userCurrency}" onchange="onBudgetChange('${row.id}', this, '${userCurrency}')" onblur="onBudgetChange('${row.id}', this, '${userCurrency}')" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; width: 80px; text-align: right; padding: 4px 8px; border-radius: 4px; outline: none;">
          </div>
        </td>
        <td style="text-align:right;">
          <div class="input-cell" style="gap: 4px;">
            <button onclick="copyBudgetToActual('${row.id}', '${userCurrency}')" style="background: var(--surface2); border: 1px solid var(--border); color: var(--accent); font-family: 'DM Mono', monospace; font-size: 10px; padding: 4px 6px; cursor: pointer; border-radius: 3px; transition: all 0.15s; line-height: 1;" onmouseover="this.style.borderColor='var(--accent)'; this.style.background='var(--surface)'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--surface2)'" title="Copy budget to actual">→</button>
            <button onclick="clearActual('${row.id}', '${userCurrency}')" style="background: var(--surface2); border: 1px solid var(--border); color: var(--red); font-family: 'DM Mono', monospace; font-size: 10px; padding: 4px 6px; cursor: pointer; border-radius: 3px; transition: all 0.15s; line-height: 1;" onmouseover="this.style.borderColor='var(--red)'; this.style.background='var(--surface)'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--surface2)'" title="Clear actual amount">×</button>
            <span class="currency-sym">${currencySym}</span>
            <input class="budget-input-dark" type="number" value="${row.actual}" data-id="${row.id}" data-currency="${userCurrency}" data-type="actual" onchange="onActualChange('${row.id}', this, '${userCurrency}')" onblur="onActualChange('${row.id}', this, '${userCurrency}')" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; width: 80px; text-align: right; padding: 4px 8px; border-radius: 4px; outline: none;">
          </div>
        </td>
        <td class="budget-val ${varianceClass}" style="text-align:right;">${formatCurrency(Math.round(variance), userCurrency)}</td>
      `;
      tbody.appendChild(tr);
    });
    
    // Add focus handlers to maintain dark background
    document.querySelectorAll('#zarBody .budget-input-dark').forEach(input => {
      const inputEl = input as HTMLInputElement;
      inputEl.addEventListener('focus', function() {
        this.style.background = 'var(--surface2)';
        this.style.borderColor = 'var(--accent)';
      });
      inputEl.addEventListener('blur', function() {
