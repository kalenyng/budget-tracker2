  async function onBudgetChange(categoryId: string, input: HTMLInputElement, currency: string) {
    const val = parseFloat(input.value) || 0;
    
    try {
      // Get current actual amount
      const currentBudget = zarData.find(r => r.id === categoryId);
      const currentActual = currentBudget?.actual || 0;
      
      const { data: { user } } = await supabase.auth.getUser();
      await supabase.from('budgets').upsert({
        category_id: categoryId,
        month: currentMonth,
        budget_amount: val,
        actual_amount: currentActual,
        user_id: user?.id
      }, { onConflict: 'category_id,month,user_id' });
      
      // Update in data array
      const index = zarData.findIndex(r => r.id === categoryId);
      if (index !== -1) {
        zarData[index].budget = val;
        zarBudgets[index] = val;
      }
      
      refreshTotals();
      rebuildTable(currency);
    } catch (error) {
      console.error('Error updating budget:', error);
    }
  }

