        <td style="text-align:right; padding-top: 16px; padding-bottom: 8px;">
          <span style="font-weight: 600; color: var(--text);">${formatCurrency(Math.round(groupBudget), userCurrency)}</span>
        </td>
        <td style="text-align:right; padding-top: 16px; padding-bottom: 8px;">
          <span style="font-weight: 600; color: var(--text);">${formatCurrency(Math.round(groupActual), userCurrency)}</span>
        </td>
        <td class="budget-val ${groupVarianceClass}" style="text-align:right; padding-top: 16px; padding-bottom: 8px; font-weight: 600;">
          ${formatCurrency(Math.round(groupVariance), userCurrency)}
        </td>
      `;
      tbody.appendChild(groupHeader);
      
      // Group items (indented) - only show if expanded
      if (isExpanded) {
        groupItems.forEach((row: CategoryData) => {
