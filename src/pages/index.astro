  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderIncomeSources() {
    const container = document.getElementById('incomeSourcesList');
    if (!container) return;
    container.innerHTML = '';

    const sym = getCurrencySymbol(userCurrency);

    incomeSources.forEach(source => {
      const row = document.createElement('div');
      row.style.cssText = 'display: flex; align-items: center; gap: 8px;';
      row.innerHTML = `
        <input type="text" value="${escapeHtml(source.source_name)}"
          style="flex: 1; background: var(--surface2); border: 1px solid var(--border); color: var(--text);
                 font-family: 'DM Mono', monospace; font-size: 12px; padding: 8px 12px; border-radius: 4px;"
          onchange="updateIncomeSourceName('${source.id}', this.value)"
          placeholder="e.g. Salary">
        <div class="input-cell" style="flex-shrink: 0;">
          <span class="currency-sym">${sym}</span>
          <input type="number" value="${source.amount || ''}"
            style="background: var(--surface2); border: 1px solid var(--border); color: var(--text);
                   font-family: 'DM Mono', monospace; font-size: 12px; padding: 8px 12px; border-radius: 4px; width: 120px; text-align: right;"
            placeholder="0"
            onchange="updateIncomeAmount('${source.id}', this.value)"
            onblur="updateIncomeAmount('${source.id}', this.value)">
        </div>
        <button onclick="removeIncomeSource('${source.id}')"
          style="background: transparent; border: 1px solid var(--border); color: var(--red);
                 font-family: 'DM Mono', monospace; font-size: 11px; padding: 6px 10px; cursor: pointer; border-radius: 4px; flex-shrink: 0;"
          onmouseover="this.style.borderColor='var(--red)'"
          onmouseout="this.style.borderColor='var(--border)'">×</button>
      `;
      container.appendChild(row);
    });

    // Update carried over display
    const carriedOverEl = document.getElementById('carriedOverDisplay');
    if (carriedOverEl) {
      carriedOverEl.textContent = carriedOver > 0
        ? formatCurrency(Math.round(carriedOver), userCurrency)
        : '—';
    }
  }

  async function addIncomeSource() {
    const name = await showPrompt('Add Income Source', 'e.g. Salary, Freelance', 'Add');
    if (!name) return;

    const { data: { user } } = await supabase.auth.getUser();

    try {
      // Create template row
      await supabase.from('incomes').upsert({
        source_name: name,
        month: '1970-01-01',
        amount: 0,
        currency: userCurrency,
        is_template: true,
        user_id: user?.id
      }, { onConflict: 'source_name,month,user_id' });

      // Create monthly row for current month
      const { data } = await supabase.from('incomes').upsert({
        source_name: name,
        month: currentMonth,
        amount: 0,
        currency: userCurrency,
        is_template: false,
        user_id: user?.id
      }, { onConflict: 'source_name,month,user_id' }).select().single();

      if (data) {
        incomeSources.push({ id: data.id, source_name: name, amount: 0 });
        renderIncomeSources();
        refreshTotals();
      }
    } catch (error: any) {
      showToast('Error adding income source: ' + error.message, 'error');
    }
  }

  async function removeIncomeSource(id: string) {
    const source = incomeSources.find(s => s.id === id);
    if (!source) return;

    const confirmed = await showConfirm(
      'Remove Income Source',
      `Remove "${source.source_name}" from all months? This deletes all monthly entries and the template.`,
      'Remove',
      true
    );
    if (!confirmed) return;

    const { data: { user } } = await supabase.auth.getUser();

    try {
      // Delete all monthly rows for this source
      await supabase.from('incomes')
        .delete()
        .eq('source_name', source.source_name)
        .eq('user_id', user?.id);

      incomeSources = incomeSources.filter(s => s.id !== id);
      renderIncomeSources();
      refreshTotals();
    } catch (error: any) {
      showToast('Error removing income source: ' + error.message, 'error');
    }
  }

  async function updateIncomeAmount(id: string, value: string) {
    const val = parseFloat(value) || 0;
    const source = incomeSources.find(s => s.id === id);
    if (!source) return;

    try {
      await supabase.from('incomes')
        .update({ amount: val })
        .eq('id', id);

      source.amount = val;
      totalIncome = incomeSources.reduce((sum, s) => sum + s.amount, 0);
      refreshTotals();
    } catch (error: any) {
      showToast('Error updating income: ' + error.message, 'error');
    }
  }

  async function updateIncomeSourceName(id: string, newName: string) {
    if (!newName.trim()) return;
    const source = incomeSources.find(s => s.id === id);
    if (!source) return;

    const { data: { user } } = await supabase.auth.getUser();

    try {
      // Update the monthly row name
      await supabase.from('incomes')
        .update({ source_name: newName.trim() })
        .eq('id', id);

      // Update the template row name
      await supabase.from('incomes')
        .update({ source_name: newName.trim() })
        .eq('source_name', source.source_name)
        .eq('is_template', true)
        .eq('user_id', user?.id);

      source.source_name = newName.trim();
    } catch (error: any) {
      showToast('Error updating name: ' + error.message, 'error');
    }
  }

  async function updateBalance(currency: string, type: string, value: string) {
    const val = parseFloat(value) || null;
    const { data: { user } } = await supabase.auth.getUser();
    
    try {
      // First, try to get existing balance
      const { data: existing } = await supabase
        .from('monthly_balances')
        .select('*')
        .eq('month', currentMonth)
        .eq('currency', userCurrency)
        .maybeSingle();
      
      const updateData = {
        month: currentMonth,
        currency: userCurrency,
        starting_balance: type === 'start' ? val : (existing?.starting_balance || null),
        ending_balance: type === 'end' ? val : (existing?.ending_balance || null),
        user_id: user?.id
      };
      
      await supabase.from('monthly_balances').upsert(updateData, {
        onConflict: 'month,currency,user_id'
      });
    } catch (error) {
      console.error('Error updating balance:', error);
    }
  }

  function changeMonth(direction: number) {
    const date = new Date(currentMonth);
    date.setMonth(date.getMonth() + direction);
    currentMonth = date.toISOString().slice(0, 7) + '-01';
    updateMonthDisplay();
    loadMonth();
  }

  function updateMonthDisplay() {
    const el = document.getElementById('monthDisplay');
    if (el) {
      const date = new Date(currentMonth);
      el.textContent = date.toLocaleString('default', { month: 'long', year: 'numeric' });
    }
  }

  function toggleGroup(groupName: string) {
    // Toggle the group state
    groupStates[groupName] = !groupStates[groupName];
    // Rebuild the table to reflect the new state
    buildZAR();
  }

  function rebuildTable(currency: string) {
    buildZAR();
  }

  function refreshTotals() {
    const zarBudgetTotal = zarBudgets.reduce((a: number, b: number) => a+b, 0);
    const zarActualTotal = zarActuals.reduce((a: number, b: number) => a+b, 0);
    const zarVariance = zarActualTotal - zarBudgetTotal;
    const zarNet = totalIncome + carriedOver - zarActualTotal;

    // Update totals
    const zarTotalBudgetEl = document.getElementById('zarTotalBudget');
    const zarTotalActualEl = document.getElementById('zarTotalActual');
    const zarTotalVarianceEl = document.getElementById('zarTotalVariance');
    
    if (zarTotalBudgetEl) zarTotalBudgetEl.textContent = formatCurrency(Math.round(zarBudgetTotal), userCurrency);
    if (zarTotalActualEl) zarTotalActualEl.textContent = formatCurrency(Math.round(zarActualTotal), userCurrency);
    if (zarTotalVarianceEl) {
      zarTotalVarianceEl.textContent = formatCurrency(Math.round(zarVariance), userCurrency);
      zarTotalVarianceEl.className = 'budget-val ' + (zarVariance > 0 ? 'over' : (zarVariance < -zarBudgetTotal * 0.1 ? 'ok' : ''));
    }

    // Update summary cards
    const sumIncomeZarEl = document.getElementById('sumIncomeZar');
    const sumBudgetZarEl = document.getElementById('sumBudgetZar');
    const sumActualZarEl = document.getElementById('sumActualZar');
    const sumVarianceZarEl = document.getElementById('sumVarianceZar');
    const sumNetZarEl = document.getElementById('sumNetZar');
    const sumNetNoteEl = document.getElementById('sumNetNote');
    
    if (sumIncomeZarEl) sumIncomeZarEl.textContent = formatCurrency(Math.round(totalIncome + carriedOver), userCurrency);
    
    const sumIncomeNoteEl = document.getElementById('sumIncomeNote');
    if (sumIncomeNoteEl) {
      sumIncomeNoteEl.textContent = carriedOver > 0
        ? `${formatCurrency(Math.round(totalIncome), userCurrency)} income + ${formatCurrency(Math.round(carriedOver), userCurrency)} carried over`
        : 'Total income this month';
    }
    if (sumBudgetZarEl) sumBudgetZarEl.textContent = formatCurrency(Math.round(zarBudgetTotal), userCurrency);
    if (sumActualZarEl) sumActualZarEl.textContent = formatCurrency(Math.round(zarActualTotal), userCurrency);
    if (sumVarianceZarEl) {
      const varianceFormatted = formatCurrency(Math.round(Math.abs(zarVariance)), userCurrency);
      sumVarianceZarEl.textContent = zarVariance >= 0 
        ? `+${varianceFormatted} over` 
        : `${varianceFormatted} under`;
      sumVarianceZarEl.style.color = zarVariance > 0 ? 'var(--red)' : 'var(--accent)';
    }
    if (sumNetZarEl) {
      sumNetZarEl.textContent = formatCurrency(Math.round(zarNet), userCurrency);
      sumNetZarEl.className = 'val ' + (zarNet >= 0 ? 'green' : 'red');
    }
    if (sumNetNoteEl) {
      const netFormatted = formatCurrency(Math.round(Math.abs(zarNet)), userCurrency);
      sumNetNoteEl.textContent = zarNet >= 0 
        ? `Surplus: ${netFormatted}` 
        : `Deficit: ${netFormatted}`;
      sumNetNoteEl.style.color = zarNet >= 0 ? 'var(--accent)' : 'var(--red)';
    }

    // Update ZAR to GBP conversion
    updateZarToGbpConversion();
  }



  async function updateExchangeRate() {
    if (!userSettings.show_currency_conversion) {
      return;
    }
    
    try {
      const baseCurrency = userSettings.base_currency || 'ZAR';
      const conversionCurrency = userSettings.conversion_currency || 'GBP';
      
      // Using exchangerate-api.com free tier (no API key needed for basic usage)
      const response = await fetch(`https://api.exchangerate-api.com/v4/latest/${baseCurrency}`);
      const data = await response.json();
      
      if (data && data.rates && data.rates[conversionCurrency]) {
        exchangeRate = parseFloat(data.rates[conversionCurrency]);
        const rateEl = document.getElementById('exchangeRate');
        const baseSymbol = getCurrencySymbol(baseCurrency as CurrencyCode);
        const convSymbol = getCurrencySymbol(conversionCurrency as CurrencyCode);
        
        if (rateEl) {
          rateEl.textContent = `1 ${baseCurrency} = ${convSymbol}${exchangeRate.toFixed(4)}`;
          rateEl.style.color = 'var(--accent)';
        }
        updateZarToGbpConversion();
      } else {
        throw new Error('Exchange rate data not available');
      }
    } catch (error) {
      console.error('Error fetching exchange rate:', error);
      const rateEl = document.getElementById('exchangeRate');
      if (rateEl) {
        rateEl.textContent = 'Error loading rate';
        rateEl.style.color = 'var(--red)';
      }
      // Fallback to a default rate if API fails
      exchangeRate = 0.042;
      updateZarToGbpConversion();
    }
  }

  function updateZarToGbpConversion() {
    if (!userSettings.show_currency_conversion) {
      return;
    }
    
    const baseCurrency = (userSettings.base_currency || 'ZAR') as CurrencyCode;
    const conversionCurrency = (userSettings.conversion_currency || 'GBP') as CurrencyCode;
    const baseSymbol = getCurrencySymbol(baseCurrency);
    const convSymbol = getCurrencySymbol(conversionCurrency);
    
    const zarBudgetTotal = zarBudgets.reduce((a: number, b: number) => a + b, 0);
    const zarActualTotal = zarActuals.reduce((a: number, b: number) => a + b, 0);
    const zarNetTotal = totalIncome + carriedOver - zarActualTotal;
    
    // Budget conversion
    const zarBudgetEl = document.getElementById('zarBudgetForConversion');
    const zarBudgetGbpEl = document.getElementById('zarBudgetConvertedGbp');
    const budgetBaseAmountEl = document.getElementById('budgetBaseAmount');
    const budgetConvAmountEl = document.getElementById('budgetConvAmount');
    
    if (zarBudgetEl) {
      zarBudgetEl.textContent = Math.round(zarBudgetTotal).toLocaleString();
    }
    if (budgetBaseAmountEl) {
      budgetBaseAmountEl.innerHTML = `${baseSymbol}<span id="zarBudgetForConversion">${Math.round(zarBudgetTotal).toLocaleString()}</span>`;
    }
    if (zarBudgetGbpEl && exchangeRate > 0) {
      const converted = zarBudgetTotal * exchangeRate;
      zarBudgetGbpEl.textContent = converted.toFixed(2);
    }
    if (budgetConvAmountEl && exchangeRate > 0) {
      const converted = zarBudgetTotal * exchangeRate;
      budgetConvAmountEl.innerHTML = `${convSymbol}<span id="zarBudgetConvertedGbp">${converted.toFixed(2)}</span>`;
    }
    
    // Actual conversion
    const zarActualEl = document.getElementById('zarActualForConversion');
    const zarActualGbpEl = document.getElementById('zarActualConvertedGbp');
    const actualBaseAmountEl = document.getElementById('actualBaseAmount');
    const actualConvAmountEl = document.getElementById('actualConvAmount');
    
    if (zarActualEl) {
      zarActualEl.textContent = Math.round(zarActualTotal).toLocaleString();
    }
    if (actualBaseAmountEl) {
      actualBaseAmountEl.innerHTML = `${baseSymbol}<span id="zarActualForConversion">${Math.round(zarActualTotal).toLocaleString()}</span>`;
    }
    if (zarActualGbpEl && exchangeRate > 0) {
      const converted = zarActualTotal * exchangeRate;
      zarActualGbpEl.textContent = converted.toFixed(2);
    }
    if (actualConvAmountEl && exchangeRate > 0) {
      const converted = zarActualTotal * exchangeRate;
      actualConvAmountEl.innerHTML = `${convSymbol}<span id="zarActualConvertedGbp">${converted.toFixed(2)}</span>`;
    }
    
    // Net conversion
    const zarNetEl = document.getElementById('zarNetForConversion');
    const zarNetGbpEl = document.getElementById('zarNetConvertedGbp');
    const netBaseAmountEl = document.getElementById('netBaseAmount');
    const netConvAmountEl = document.getElementById('netConvAmount');
    
    if (zarNetEl) {
      zarNetEl.textContent = Math.round(zarNetTotal).toLocaleString();
    }
    if (netBaseAmountEl) {
      netBaseAmountEl.innerHTML = `${baseSymbol}<span id="zarNetForConversion">${Math.round(zarNetTotal).toLocaleString()}</span>`;
    }
    if (zarNetGbpEl && exchangeRate > 0) {
      const converted = zarNetTotal * exchangeRate;
      zarNetGbpEl.textContent = converted.toFixed(2);
      zarNetGbpEl.style.color = zarNetTotal >= 0 ? 'var(--accent)' : 'var(--red)';
    }
    if (netConvAmountEl && exchangeRate > 0) {
      const converted = zarNetTotal * exchangeRate;
      netConvAmountEl.innerHTML = `${convSymbol}<span id="zarNetConvertedGbp">${converted.toFixed(2)}</span>`;
      netConvAmountEl.style.color = zarNetTotal >= 0 ? 'var(--accent)' : 'var(--red)';
    }
  }

  async function copyFromLastMonth() {
    const confirmed = await showConfirm(
      'Copy Last Month',
      'Copy all budget amounts from the previous month into this month? This will overwrite any existing budget values for this month.',
      'Copy',
      false
    );
    if (!confirmed) return;

    const prevMonthDate = new Date(currentMonth);
    prevMonthDate.setMonth(prevMonthDate.getMonth() - 1);
    const prevMonth = prevMonthDate.toISOString().slice(0, 7) + '-01';

    try {
      const { data: { user } } = await supabase.auth.getUser();

      // Load previous month's budgets
      const { data: prevBudgets, error } = await supabase
        .from('budgets')
        .select('category_id, budget_amount')
        .eq('month', prevMonth)
        .eq('user_id', user?.id);

      if (error) throw error;

      if (!prevBudgets || prevBudgets.length === 0) {
        showToast('No budget data found for previous month', 'error');
        return;
      }

      // Upsert into current month
      const upserts = prevBudgets.map(b => ({
        category_id: b.category_id,
        month: currentMonth,
        budget_amount: b.budget_amount,
        actual_amount: 0,
        user_id: user?.id
      }));

      const { error: upsertError } = await supabase
        .from('budgets')
        .upsert(upserts, { onConflict: 'category_id,month,user_id' });

      if (upsertError) throw upsertError;

      showToast('Budget copied from previous month');
      await loadMonth();
    } catch (error: any) {
      showToast('Error copying budget: ' + error.message, 'error');
    }
  }

  // Make functions available globally
  window.onBudgetChange = onBudgetChange;
  window.onActualChange = onActualChange;
  window.copyBudgetToActual = copyBudgetToActual;
  window.clearActual = clearActual;
  window.updateBalance = updateBalance;
  window.addIncomeSource = addIncomeSource;
  window.removeIncomeSource = removeIncomeSource;
  window.updateIncomeAmount = updateIncomeAmount;
  window.updateIncomeSourceName = updateIncomeSourceName;
  window.updateExchangeRate = updateExchangeRate;
  window.toggleGroup = toggleGroup;
  window.loadMonth = loadMonth;
  window.handleSignOut = handleSignOut;
  window.changeMonth = changeMonth;
  window.copyFromLastMonth = copyFromLastMonth;

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

