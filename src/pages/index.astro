---
// Yearly overview page
import { supabase } from '../lib/supabase';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yearly Overview - Budget Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
<div class="page">

  <header>
    <div class="label">Personal finance tracker</div>
    <h1>Yearly<span> Overview</span></h1>
    <div class="subtitle">Financial year: April to March</div>
    
    <!-- Navigation -->
    <div style="margin-top: 20px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <a href="/month" class="currency-btn" style="text-decoration: none; display: inline-block;">Monthly Tracker</a>
      <a href="/transactions" class="currency-btn" style="text-decoration: none; display: inline-block;">Transactions</a>
      <a href="/mobile-sort" class="currency-btn" style="text-decoration: none; display: inline-block; color: var(--accent); border-color: var(--accent);">⌖ Quick Sort</a>
      <a href="/settings" class="currency-btn" style="text-decoration: none; display: inline-block;">Settings</a>
      <div style="display: flex; align-items: center; gap: 0; margin-left: 12px;">
        <button onclick="changeFY(-1)" style="background: var(--surface2); border: 1px solid var(--border); border-right: none; color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 13px; padding: 6px 12px; cursor: pointer; border-radius: 4px 0 0 4px; transition: all 0.15s;" onmouseover="this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='var(--border)'">‹</button>
        <div id="yearLabel" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; padding: 6px 16px; min-width: 100px; text-align: center;"></div>
        <button onclick="changeFY(1)" style="background: var(--surface2); border: 1px solid var(--border); border-left: none; color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 13px; padding: 6px 12px; cursor: pointer; border-radius: 0 4px 4px 0; transition: all 0.15s;" onmouseover="this.style.color='var(--accent)'; this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-dim)'; this.style.borderColor='var(--border)'">›</button>
      </div>
      <div id="currentUserEmail" style="margin-left: auto; padding: 6px 12px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface2); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 11px; max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="Signed in user">Loading account...</div>
      <button class="currency-btn" onclick="handleSignOut()" style="color: var(--red);" title="Sign Out">Sign Out</button>
    </div>
    
  </header>

  <!-- Year Summary -->
  <div class="summary-grid" id="yearSummary" style="margin-bottom: 24px;">
    <div class="summary-card">
      <div class="label">Total Income</div>
      <div class="val green" id="yearIncome">—</div>
      <div class="note">For the year</div>
    </div>
    <div class="summary-card">
      <div class="label">Total Budget</div>
      <div class="val" id="yearBudget">—</div>
      <div class="note">Planned expenses</div>
    </div>
    <div class="summary-card">
      <div class="label">Total Actual</div>
      <div class="val" id="yearActual">—</div>
      <div class="note">Actual spending</div>
    </div>
    <div class="summary-card">
      <div class="label">Var</div>
      <div class="val" id="yearNet">—</div>
      <div class="note" id="yearNetNote">—</div>
    </div>
  </div>

  <!-- Currency Conversion Summary -->
  <div class="balance-section" id="zarToGbpSummary" style="margin-bottom: 48px; display: none;">
    <div class="label" id="conversionLabel">Currency Conversion</div>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 24px; margin-top: 16px;">
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Exchange Rate</label>
        <div style="font-family: 'DM Mono', monospace; font-size: 16px; font-weight: 500; color: var(--accent);">
          <span id="exchangeRate">Loading...</span>
          <button onclick="updateExchangeRate()" style="background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 10px; padding: 4px 8px; margin-left: 8px; cursor: pointer; border-radius: 3px; transition: all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-dim)'">Refresh</button>
        </div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Budget Total</label>
        <div style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--text);"><span id="yearBudgetZar">0</span></div>
        <div style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--accent); margin-top: 4px;"><span id="yearBudgetGbp">0</span></div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Actual Total</label>
        <div style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--text);"><span id="yearActualZar">0</span></div>
        <div style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--accent); margin-top: 4px;"><span id="yearActualGbp">0</span></div>
      </div>
      <div>
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 4px;">Net Total</label>
        <div style="font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: var(--text);"><span id="yearNetZar">0</span></div>
        <div style="font-family: 'DM Mono', monospace; font-size: 14px; font-weight: 500; color: var(--accent); margin-top: 4px;"><span id="yearNetGbp">0</span></div>
      </div>
    </div>
  </div>

  <!-- Category Breakdown -->
  <div id="categoryBreakdown">
    <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
      <div class="section-title" style="margin-bottom: 0;">Annual Category Breakdown</div>
      <div class="chart-global-toggle" style="display: flex; gap: 4px; align-items: center;">
        <span style="color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.04em; margin-right: 4px;">VIEW ALL AS</span>
        <button class="chart-mode-btn active" onclick="window.switchAllChartMode('actual', this)">Actual</button>
        <button class="chart-mode-btn" onclick="window.switchAllChartMode('burn', this)">Burn Rate</button>
      </div>
    </div>
    <div id="categoriesContainer"></div>
  </div>

  <footer>
    Budget Tracker · FY Overview
    <div style="margin-top: 12px;">
      <a href="/mobile-sort" style="display: inline-block; background: var(--surface2); border: 1px solid var(--accent); color: var(--accent); font-family: 'DM Mono', monospace; font-size: 11px; letter-spacing: 0.1em; padding: 8px 18px; border-radius: 4px; text-decoration: none; transition: background 0.15s;" onmouseover="this.style.background='var(--accent)';this.style.color='#0d0f0e'" onmouseout="this.style.background='var(--surface2)';this.style.color='var(--accent)'">⌖ Quick Sort</a>
    </div>
  </footer>

</div>

<div id="catModal" style="display:none; position:fixed; inset:0; z-index:9997; background: rgba(0,0,0,0.6); backdrop-filter: blur(2px);" onclick="closeCatModal(event)">
  <div id="catModalInner" style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:32px; min-width:480px; max-width:640px; width:90%;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:24px;">
      <h2 id="catModalName" style="font-family:'Fraunces',serif; font-size:24px; font-weight:300; font-style:italic; color:var(--text);"></h2>
      <button onclick="closeCatModal()" style="background:transparent; border:none; color:var(--text-dim); font-family:'DM Mono',monospace; font-size:18px; cursor:pointer; padding:0 4px;">×</button>
    </div>
    <table id="catModalTable" style="width:100%; border-collapse:collapse;"></table>
    <div id="catModalTotals" style="margin-top:16px; padding-top:16px; border-top:1px solid var(--border); display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px;"></div>
  </div>
</div>

<button class="theme-toggle" onclick="toggleTheme()" id="themeToggle">☀ Light</button>

<div id="chartTooltip" style="position: fixed; background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 11px; padding: 6px 10px; border-radius: 4px; pointer-events: none; opacity: 0; transition: opacity 0.1s; z-index: 9998;"></div>

<script>
  import { supabase } from '../lib/supabase';
  import { getCurrentUser, onAuthStateChange, signOut } from '../lib/auth';
  import { formatCurrency, getCurrencySymbol, type CurrencyCode } from '../lib/currency';
  import { showConfirm } from '../lib/dialogs';
  import type { User } from '@supabase/supabase-js';

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = theme === 'light' ? '☾ Dark' : '☀ Light';
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }

  // Apply saved theme immediately on load
  const savedTheme = localStorage.getItem('theme') || 'dark';
  applyTheme(savedTheme);

  // Check authentication on page load
  async function checkAuth() {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = '/auth';
      return false;
    }
    updateCurrentUserEmail(user);
    return true;
  }

  function updateCurrentUserEmail(user: User | null) {
    const emailEl = document.getElementById('currentUserEmail');
    if (!emailEl) return;
    emailEl.textContent = user?.email || 'Signed in';
    emailEl.title = user?.email || 'Signed in user';
  }

  // Handle sign out
  async function handleSignOut() {
    if (await showConfirm('Sign Out', 'Are you sure you want to sign out?', 'Sign Out')) {
      await signOut();
      window.location.href = '/auth';
    }
  }

  // Type definitions
  interface MonthlyData {
    month: string;
    monthName: string;
    income: number;
    budget: number;
    actual: number;
    net: number;
    order: number; // Financial year order: April=0, May=1, ..., March=11
  }

  interface CategoryData {
    id: string;
    name: string;
    annualBudget: number;
    annualActual: number;
  }

  // Window interface extension
  declare global {
    interface Window {
      loadYear: () => Promise<void>;
      updateExchangeRate: () => Promise<void>;
      changeFY: (direction: number) => void;
      handleSignOut: () => Promise<void>;
      toggleTheme: () => void;
      openCatModal: (categoryId: string) => void;
      closeCatModal: (event?: MouseEvent) => void;
      switchChartMode: (button: HTMLButtonElement, catId: string, mode: 'actual' | 'burn') => void;
      switchAllChartMode: (mode: 'actual' | 'burn', btn: HTMLButtonElement) => void;
    }
  }

  // Default to current financial year start
  // If current month is Jan/Feb/Mar, financial year started last year
  const now = new Date();
  let currentYear = now.getMonth() < 3 ? now.getFullYear() - 1 : now.getFullYear();
  let monthlyData: MonthlyData[] = [];
  let categoryData: CategoryData[] = [];
  let categoryMonthlyActuals: Record<string, Record<string, number>> = {};
  let exchangeRate = 0;
  let yearIncome = 0;
  let yearBudget = 0;
  let yearActual = 0;
  let yearNet = 0;
  let userCurrency: CurrencyCode = 'ZAR'; // User's preferred currency
  let showCurrencyConversion = false;
  let conversionCurrency: CurrencyCode = 'GBP';

  function updateYearLabel() {
    const labelEl = document.getElementById('yearLabel');
    if (labelEl) labelEl.textContent = `FY ${currentYear}/${String(currentYear + 1).slice(2)}`;
  }

  function changeFY(direction: number) {
    currentYear += direction;
    updateYearLabel();
    loadYear();
  }

  // Load user currency preference
  async function loadUserCurrency() {
    try {
      const user = await getCurrentUser();
      if (!user) return;

      const { data: settingsRows } = await supabase
        .from('user_settings')
        .select('key, value, preferred_currency')
        .eq('user_id', user.id);

      const settingsMap = Object.fromEntries((settingsRows || []).map(s => [s.key, s.value]));
      userCurrency = (settingsMap['preferred_currency'] as CurrencyCode) || 'ZAR';
      showCurrencyConversion = settingsMap['show_currency_conversion'] === 'true';
      conversionCurrency = (settingsMap['conversion_currency'] as CurrencyCode) || 'GBP';

      // Update conversion section visibility
      const conversionSection = document.getElementById('zarToGbpSummary');
      if (conversionSection) {
        conversionSection.style.display = showCurrencyConversion ? 'block' : 'none';
      }

      const conversionLabel = document.getElementById('conversionLabel');
      if (conversionLabel && showCurrencyConversion) {
        conversionLabel.textContent = `${userCurrency} to ${conversionCurrency} Conversion`;
      }
    } catch (error) {
      console.error('Error loading user currency:', error);
    }
  }

  // Initialize
  async function init() {
    try {
      onAuthStateChange((_event, session) => {
        updateCurrentUserEmail(session?.user ?? null);
        if (!session?.user) {
          window.location.href = '/auth';
        }
      });

      // Check authentication first
      const isAuthenticated = await checkAuth();
      if (!isAuthenticated) {
        return;
      }
      
      // Load user currency preference
      await loadUserCurrency();
      
      // Test connection
      const { data: testData, error: testError } = await supabase
        .from('categories')
        .select('id, name')
        .limit(1);
      
      if (testError) {
        console.error('Connection failed:', testError.message);
        return;
      }
      
      updateYearLabel();
      await loadYear();
    } catch (error) {
      console.error('Initialization error:', error);
    }
  }

  function showSkeletons() {
    // Year summary cards skeleton
    const yearSummary = document.getElementById('yearSummary');
    if (yearSummary) {
      yearSummary.innerHTML = `
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 50%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 50%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 50%;"></div>
        </div>
        <div class="skeleton-card">
          <div class="skeleton skeleton-block" style="width: 40%;"></div>
          <div class="skeleton skeleton-val"></div>
          <div class="skeleton skeleton-block" style="width: 50%;"></div>
        </div>
      `;
    }

    // Category breakdown skeleton — 12 category card placeholders
    const categoriesContainer = document.getElementById('categoriesContainer');
    if (categoriesContainer) {
      categoriesContainer.innerHTML = Array(12).fill(`
        <div class="cat-card" style="pointer-events: none;">
          <div class="skeleton skeleton-block" style="width: 55%; height: 16px; margin-bottom: 16px;"></div>
          <div class="skeleton skeleton-block" style="width: 40%; margin-bottom: 6px;"></div>
          <div class="skeleton skeleton-block" style="width: 65%; height: 14px; margin-bottom: 12px;"></div>
          <div class="skeleton skeleton-block" style="width: 40%; margin-bottom: 6px;"></div>
          <div class="skeleton skeleton-block" style="width: 65%; height: 14px; margin-bottom: 12px;"></div>
          <div class="skeleton skeleton-block" style="width: 40%; margin-bottom: 6px;"></div>
          <div class="skeleton skeleton-block" style="width: 65%; height: 14px; margin-bottom: 14px;"></div>
          <div class="skeleton skeleton-block" style="width: 100%; height: 4px; border-radius: 2px;"></div>
        </div>
      `).join('');
    }
  }

  function restoreSummaryCards() {
    const yearSummary = document.getElementById('yearSummary');
    if (!yearSummary) return;
    yearSummary.innerHTML = `
      <div class="summary-card">
        <div class="label">Total Income</div>
        <div class="val green" id="yearIncome">—</div>
        <div class="note">For the year</div>
      </div>
      <div class="summary-card">
        <div class="label">Total Budget</div>
        <div class="val" id="yearBudget">—</div>
        <div class="note">Planned expenses</div>
      </div>
      <div class="summary-card">
        <div class="label">Total Actual</div>
        <div class="val" id="yearActual">—</div>
        <div class="note">Actual spending</div>
      </div>
      <div class="summary-card">
        <div class="label">Var</div>
        <div class="val" id="yearNet">—</div>
        <div class="note" id="yearNetNote">—</div>
      </div>
    `;
  }

  async function loadYear() {
    showSkeletons();
    
    try {
      // Get current user first (needed for user_id in queries)
      const { data: { user } } = await supabase.auth.getUser();
      
      // Financial year: April (month 3) of currentYear to March (month 2) of currentYear+1
      // Build months array: April, May, ..., December, January, February, March
      const months: string[] = [];
      // First 9 months: April (3) through December (11) of currentYear
      for (let i = 0; i < 9; i++) {
        const monthIndex = 3 + i; // April = month index 3
        // Use UTC to avoid timezone issues
        const monthStr = `${currentYear}-${String(monthIndex + 1).padStart(2, '0')}-01`;
        months.push(monthStr);
      }
      // Last 3 months: January (0), February (1), March (2) of currentYear+1
      for (let i = 0; i < 3; i++) {
        const monthIndex = i; // January = 0, February = 1, March = 2
        // Use UTC to avoid timezone issues
        const monthStr = `${currentYear + 1}-${String(monthIndex + 1).padStart(2, '0')}-01`;
        months.push(monthStr);
      }
      
      // Load all income sources for all months (sum per month)
      const { data: incomes } = await supabase
        .from('incomes')
        .select('month, amount')
        .in('month', months)
        .eq('is_template', false);

      const incomeMap: Record<string, number> = {};
      (incomes || []).forEach(inc => {
        const m = inc.month;
        incomeMap[m] = (incomeMap[m] || 0) + parseFloat(inc.amount || 0);
      });

      // Ensure every month has at least 0 in the incomeMap (no undefined / NaN)
      // NOTE: carry-over balances are intentionally NOT added here — they would
      // cause the same money to be counted multiple times in the yearly totals.
      for (let i = 0; i < months.length; i++) {
        const month = months[i];
        if (incomeMap[month] === undefined) incomeMap[month] = 0;
      }

      // Load all categories with their monthly_amount defaults
      const { data: allCategories } = await supabase
        .from('categories')
        .select('id, name, monthly_amount');
      const catMonthlyMap: Record<string, { name: string; monthlyAmount: number }> = {};
      (allCategories || []).forEach(c => {
        catMonthlyMap[c.id] = { name: c.name, monthlyAmount: parseFloat(c.monthly_amount || 0) };
      });

      // Load budgets for all months (RLS should filter by user_id, but we'll be explicit)
      const { data: budgets, error: budgetError } = await supabase
        .from('budgets')
        .select('month, category_id, budget_amount, actual_amount')
        .in('month', months);

      if (budgetError) {
        console.error('Error loading budgets:', budgetError);
      }

      const budgetMap: Record<string, number> = {};
      const actualMap: Record<string, number> = {};
      const catMap: Record<string, CategoryData> = {};
      categoryMonthlyActuals = {};
      (budgets || []).forEach(b => {
        const month = b.month;
        const budgetAmount = parseFloat(b.budget_amount || 0);
        const actualAmount = parseFloat(b.actual_amount || 0);
        budgetMap[month] = (budgetMap[month] || 0) + budgetAmount;
        actualMap[month] = (actualMap[month] || 0) + actualAmount;

        // Accumulate per-category actual totals
        const catId = b.category_id;
        if (catId) {
          if (!catMap[catId]) {
            const catInfo = catMonthlyMap[catId] || { name: 'Unknown', monthlyAmount: 0 };
            // annualBudget = monthly_amount * 12 (category default, not summed row budgets)
            catMap[catId] = { id: catId, name: catInfo.name, annualBudget: catInfo.monthlyAmount * 12, annualActual: 0 };
          }
          catMap[catId].annualActual += actualAmount;

          // Accumulate per-category per-month actuals for sparklines
          if (!categoryMonthlyActuals[catId]) categoryMonthlyActuals[catId] = {};
          categoryMonthlyActuals[catId][month] = (categoryMonthlyActuals[catId][month] || 0) + actualAmount;
        }
      });

      // Also include categories that have a monthly_amount but no budget rows yet this FY
      Object.entries(catMonthlyMap).forEach(([catId, catInfo]) => {
        if (!catMap[catId] && catInfo.monthlyAmount > 0) {
          catMap[catId] = { id: catId, name: catInfo.name, annualBudget: catInfo.monthlyAmount * 12, annualActual: 0 };
        }
      });

      categoryData = Object.values(catMap).sort((a, b) => a.name.localeCompare(b.name));

      // Build monthly data with explicit order (April=0, May=1, ..., March=11)
      // Reset monthlyData to ensure we only have current financial year months
      monthlyData = [];
      months.forEach((month, index) => {
        const monthDate = new Date(month);
        const monthName = monthDate.toLocaleString('default', { month: 'long', year: 'numeric' });
        const income = incomeMap[month] || 0;
        const budget = budgetMap[month] || 0;
        const actual = actualMap[month] || 0;
        const net = income - actual;

        monthlyData.push({
          month,
          monthName,
          income,
          budget,
          actual,
          net,
          order: index // Preserve financial year order: April=0, May=1, ..., March=11
        });
      });

      // Calculate year totals
      yearIncome = monthlyData.reduce((sum, m) => sum + m.income, 0);
      yearBudget = monthlyData.reduce((sum, m) => sum + m.budget, 0);
      yearActual = monthlyData.reduce((sum, m) => sum + m.actual, 0);
      yearNet = yearIncome - yearActual;

      // Restore summary cards before writing values
      restoreSummaryCards();

      // Update year summary
      const yearIncomeEl = document.getElementById('yearIncome');
      const yearBudgetEl = document.getElementById('yearBudget');
      const yearActualEl = document.getElementById('yearActual');
      const yearNetEl = document.getElementById('yearNet');
      const yearNetNoteEl = document.getElementById('yearNetNote');
      
      if (yearIncomeEl) yearIncomeEl.textContent = formatCurrency(Math.round(yearIncome), userCurrency);
      if (yearBudgetEl) yearBudgetEl.textContent = formatCurrency(Math.round(yearBudget), userCurrency);
      if (yearActualEl) yearActualEl.textContent = formatCurrency(Math.round(yearActual), userCurrency);
      if (yearNetEl) {
        yearNetEl.textContent = formatCurrency(Math.round(yearNet), userCurrency);
        yearNetEl.className = 'val ' + (yearNet >= 0 ? 'green' : 'red');
      }
      if (yearNetNoteEl) {
        yearNetNoteEl.textContent = yearNet >= 0 ? 'Surplus' : 'Deficit';
        yearNetNoteEl.style.color = yearNet >= 0 ? 'var(--accent)' : 'var(--red)';
      }

      // Build category breakdown
      buildCategoryBreakdown();
      
      // Update conversions
      updateYearConversions();
      await updateExchangeRate();
    } catch (error) {
      console.error('Error loading year:', error);
    }
  }

  // ── Chart rendering helpers ─────────────────────────────────────────────────

  function buildChartSVGContent(catId: string, mode: 'actual' | 'burn'): string {
    const W = 300, H = 80, padTop = 8, padBottom = 4;
    const plotH = H - padTop - padBottom;
    const colW = (W / 18).toFixed(2);
    const fyMonthKeys = monthlyData.map(m => m.month);
    const fyMonthLabels = ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'];
    const cat = categoryData.find(c => c.id === catId);
    if (!cat) return '';
    const monthlyBudget = cat.annualBudget / 12;
    const monthActuals = categoryMonthlyActuals[cat.id] || {};
    const actuals = fyMonthKeys.map(mk => monthActuals[mk] || 0);
    // Find last month index where monthly actual > 0
    const lastDataIdx = actuals.reduce((last, v, i) => v > 0 ? i : last, -1);

    if (mode === 'actual') {
      const maxVal = Math.max(...actuals, monthlyBudget, 1);
      const toY = (v: number) => padTop + (1 - v / maxVal) * plotH;
      const refY = toY(monthlyBudget).toFixed(2);
      const refLine = monthlyBudget > 0 ? `<line x1="0" y1="${refY}" x2="${W}" y2="${refY}" class="sparkline-ref" />` : '';
      // If no data yet, render only the reference line
      if (lastDataIdx === -1) return refLine;
      const slicedActuals = actuals.slice(0, lastDataIdx + 1);
      const polyPoints = slicedActuals.map((v, i) => `${((i / 11) * W).toFixed(2)},${toY(v).toFixed(2)}`).join(' ');
      return [
        refLine,
        `<polyline points="${polyPoints}" class="sparkline-line" />`,
        slicedActuals.map((v, i) => `<circle cx="${((i / 11) * W).toFixed(2)}" cy="${toY(v).toFixed(2)}" r="2.5" class="sparkline-dot" />`).join(''),
        // Hit rects span all 12 months; only months with data get the sparkline-hit class (tooltip)
        actuals.map((v, i) => {
          const rx = ((i / 11) * W - W / 36).toFixed(2);
          const hitClass = i <= lastDataIdx ? 'sparkline-hit' : '';
          return `<rect x="${rx}" y="0" width="${colW}" height="${H}" fill="transparent" stroke="none" class="${hitClass}" data-month="${fyMonthLabels[i]}" data-amount="${v}" />`;
        }).join(''),
      ].join('');
    }

    // Burn Rate mode — cumulative actuals vs straight-line expected
    const cumActuals: number[] = [];
    let cum = 0;
    for (const v of actuals) { cum += v; cumActuals.push(cum); }
    const annualBudget = monthlyBudget * 12;
    const maxVal = Math.max(...cumActuals, annualBudget, 1);
    const toY = (v: number) => padTop + (1 - v / maxVal) * plotH;
    // Colour: red if cumulative actual at last active month exceeds expected spend at that month
    let colour: string;
    if (lastDataIdx === -1) colour = 'var(--accent)'; // no data yet
    else {
      const cumAtLast = cumActuals[lastDataIdx];
      const expectedAtLast = monthlyBudget * (lastDataIdx + 1);
      const isOver = annualBudget > 0 && cumAtLast > expectedAtLast;
      colour = isOver ? 'var(--red)' : 'var(--accent)';
    }
    // Reference line: straight diagonal from (x=0, y=0) to (x=W, y=annualBudget) — always full width
    const refY1 = toY(0).toFixed(2);
    const refY2 = toY(annualBudget).toFixed(2);
    const refLine = annualBudget > 0 ? `<line x1="0" y1="${refY1}" x2="${W}" y2="${refY2}" class="sparkline-ref" />` : '';
    // If no data yet, render only the reference line
    if (lastDataIdx === -1) return refLine;
    const slicedCumActuals = cumActuals.slice(0, lastDataIdx + 1);
    const polyPoints = slicedCumActuals.map((v, i) => `${((i / 11) * W).toFixed(2)},${toY(v).toFixed(2)}`).join(' ');
    return [
      refLine,
      `<polyline points="${polyPoints}" class="sparkline-line" style="stroke:${colour};" />`,
      slicedCumActuals.map((v, i) => `<circle cx="${((i / 11) * W).toFixed(2)}" cy="${toY(v).toFixed(2)}" r="2.5" class="sparkline-dot" style="fill:${colour};" />`).join(''),
      // Hit rects span all 12 months; only months with data get the sparkline-hit class (tooltip)
      actuals.map((_v, i) => {
        const rx = ((i / 11) * W - W / 36).toFixed(2);
        const hitClass = i <= lastDataIdx ? 'sparkline-hit' : '';
        return `<rect x="${rx}" y="0" width="${colW}" height="${H}" fill="transparent" stroke="none" class="${hitClass}" data-month="${fyMonthLabels[i]}" data-amount="${actuals[i]}" />`;
      }).join(''),
    ].join('');
  }

  function attachChartTooltips(card: HTMLElement): void {
    const tooltip = document.getElementById('chartTooltip');
    if (!tooltip) return;
    card.querySelectorAll<SVGRectElement>('rect.sparkline-hit').forEach(rect => {
      rect.addEventListener('mouseover', (e: MouseEvent) => {
        const month = rect.dataset.month || '';
        const amount = parseFloat(rect.dataset.amount || '0');
        tooltip.textContent = `${month}  ${formatCurrency(Math.round(amount), userCurrency)}`;
        tooltip.style.opacity = '1';
        tooltip.style.left = `${e.clientX + 12}px`;
        tooltip.style.top = `${e.clientY - 28}px`;
      });
      rect.addEventListener('mousemove', (e: MouseEvent) => {
        tooltip.style.left = `${e.clientX + 12}px`;
        tooltip.style.top = `${e.clientY - 28}px`;
      });
      rect.addEventListener('mouseout', () => { tooltip.style.opacity = '0'; });
    });
  }

  function switchChartMode(button: HTMLButtonElement, catId: string, mode: 'actual' | 'burn'): void {
    const card = button.closest('.cat-card') as HTMLElement | null;
    if (!card) return;
    card.dataset.chartMode = mode;
    card.querySelectorAll<HTMLButtonElement>('.chart-mode-btn').forEach(b => b.classList.remove('active'));
    button.classList.add('active');
    const svgEl = card.querySelector('.sparkline-svg');
    if (svgEl) {
      svgEl.innerHTML = buildChartSVGContent(catId, mode);
      attachChartTooltips(card);
    }
  }

  function switchAllChartMode(mode: 'actual' | 'burn', btn: HTMLButtonElement): void {
    // Update the global toggle button states
    const globalRow = btn.closest('.chart-global-toggle');
    if (globalRow) {
      globalRow.querySelectorAll<HTMLButtonElement>('button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }
    // Switch every card to the chosen mode
    document.querySelectorAll<HTMLElement>('.cat-card').forEach(card => {
      const catId = card.dataset.catId || '';
      const modeBtn = Array.from(card.querySelectorAll<HTMLButtonElement>('.chart-mode-btn'))
        .find(b => mode === 'actual' ? b.textContent === 'Actual' : b.textContent === 'Burn Rate');
      if (modeBtn) switchChartMode(modeBtn, catId, mode);
    });
  }

  function buildCategoryBreakdown() {
    const container = document.getElementById('categoriesContainer');
    if (!container) return;

    container.innerHTML = '';

    // Financial year month labels in order: Apr … Mar
    const fyMonthLabels = ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'];

    categoryData.forEach(cat => {
      const remaining = cat.annualBudget - cat.annualActual;
      const remainingClass = remaining < 0 ? 'red' : 'green';
      const progressPct = cat.annualBudget > 0
        ? Math.min((cat.annualActual / cat.annualBudget) * 100, 100)
        : 0;
      const overBudget = cat.annualActual > cat.annualBudget;

      const labelSpans = fyMonthLabels.map(lbl => `<span>${lbl}</span>`).join('');

      const card = document.createElement('div');
      card.className = 'cat-card';
      card.dataset.catId = cat.id;
      card.dataset.chartMode = 'actual';

      card.innerHTML = `
        <div class="cat-header">
          <div class="cat-name">${cat.name}</div>
          <button class="cat-detail-btn" onclick="openCatModal('${cat.id}')">See detail</button>
        </div>
        <div class="cat-row">
          <span class="label">Annual Budget</span>
          <span class="cat-val">${formatCurrency(Math.round(cat.annualBudget), userCurrency)}</span>
        </div>
        <div class="cat-row">
          <span class="label">Spent</span>
          <span class="cat-val">${formatCurrency(Math.round(cat.annualActual), userCurrency)}</span>
        </div>
        <div class="cat-row">
          <span class="label">Remaining</span>
          <span class="cat-val ${remainingClass}">${formatCurrency(Math.round(Math.abs(remaining)), userCurrency)}${remaining < 0 ? ' over' : ''}</span>
        </div>
        <div class="cat-progress-track">
          <div class="cat-progress-bar ${overBudget ? 'over' : ''}" style="width: ${progressPct}%;"></div>
        </div>
        <div class="chart-toggle-row">
          <button class="chart-mode-btn active" onclick="event.stopPropagation(); window.switchChartMode(this, '${cat.id}', 'actual')">Actual</button>
          <button class="chart-mode-btn" onclick="event.stopPropagation(); window.switchChartMode(this, '${cat.id}', 'burn')">Burn Rate</button>
        </div>
        <div style="border-top: 1px solid var(--border); margin: 8px 0 16px;"></div>
        <svg viewBox="0 0 300 80" class="sparkline-svg">${buildChartSVGContent(cat.id, 'actual')}</svg>
        <div class="chart-month-labels">${labelSpans}</div>
      `;

      container.appendChild(card);
      attachChartTooltips(card);
    });

    if (categoryData.length === 0) {
      container.innerHTML = `<div style="padding: 32px; color: var(--text-dim); font-size: 13px; grid-column: 1 / -1;">No category data for this financial year.</div>`;
    }
  }

  async function updateExchangeRate() {
    if (!showCurrencyConversion) {
      return;
    }
    
    try {
      // Using exchangerate-api.com free tier (no API key needed for basic usage)
      // Fetching exchange rate from user's currency to conversion currency
      const response = await fetch(`https://api.exchangerate-api.com/v4/latest/${userCurrency}`);
      const data = await response.json();
      
      if (data && data.rates && data.rates[conversionCurrency]) {
        exchangeRate = parseFloat(data.rates[conversionCurrency]);
        const rateEl = document.getElementById('exchangeRate');
        const conversionSym = getCurrencySymbol(conversionCurrency);
        if (rateEl) {
          rateEl.textContent = `1 ${userCurrency} = ${conversionSym}${exchangeRate.toFixed(4)}`;
          rateEl.style.color = 'var(--accent)';
        }
        updateYearConversions();
      } else {
        throw new Error('Exchange rate data not available');
      }
    } catch (error) {
      console.error('Error fetching exchange rate:', error);
      const rateEl = document.getElementById('exchangeRate');
      if (rateEl) {
        rateEl.textContent = 'Error loading rate';
        rateEl.style.color = 'var(--red)';
      }
      // Fallback to a default rate
      exchangeRate = 0.042;
      updateYearConversions();
    }
  }

  function updateYearConversions() {
    if (!showCurrencyConversion) {
      return;
    }
    
    const conversionSym = getCurrencySymbol(conversionCurrency);
    
    // Budget conversion
    const yearBudgetZarEl = document.getElementById('yearBudgetZar');
    const yearBudgetGbpEl = document.getElementById('yearBudgetGbp');
    if (yearBudgetZarEl) {
      yearBudgetZarEl.textContent = formatCurrency(Math.round(yearBudget), userCurrency);
    }
    if (yearBudgetGbpEl && exchangeRate > 0) {
      const converted = yearBudget * exchangeRate;
      yearBudgetGbpEl.textContent = `${conversionSym}${converted.toFixed(2)}`;
    }
    
    // Actual conversion
    const yearActualZarEl = document.getElementById('yearActualZar');
    const yearActualGbpEl = document.getElementById('yearActualGbp');
    if (yearActualZarEl) {
      yearActualZarEl.textContent = formatCurrency(Math.round(yearActual), userCurrency);
    }
    if (yearActualGbpEl && exchangeRate > 0) {
      const converted = yearActual * exchangeRate;
      yearActualGbpEl.textContent = `${conversionSym}${converted.toFixed(2)}`;
    }
    
    // Net conversion
    const yearNetZarEl = document.getElementById('yearNetZar');
    const yearNetGbpEl = document.getElementById('yearNetGbp');
    if (yearNetZarEl) {
      yearNetZarEl.textContent = formatCurrency(Math.round(yearNet), userCurrency);
    }
    if (yearNetGbpEl && exchangeRate > 0) {
      const converted = yearNet * exchangeRate;
      yearNetGbpEl.textContent = `${conversionSym}${converted.toFixed(2)}`;
      yearNetGbpEl.style.color = yearNet >= 0 ? 'var(--accent)' : 'var(--red)';
    }
  }

  // Financial year month labels in order: Apr → Mar
  const FY_MONTH_LABELS = ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar'];
  const FY_MONTH_NAMES  = ['April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December', 'January', 'February', 'March'];

  function openCatModal(categoryId: string) {
    const cat = categoryData.find(c => c.id === categoryId);
    if (!cat) return;

    const monthlyAmount = cat.annualBudget / 12;
    const actuals = categoryMonthlyActuals[categoryId] || {};

    // monthlyData is already ordered Apr→Mar
    const fyMonthKeys = monthlyData.map(m => m.month);

    // Build table rows
    const rowsHtml = fyMonthKeys.map((mk, i) => {
      const actual = actuals[mk] || 0;
      const variance = actual - monthlyAmount; // positive = over budget
      const varianceColor = variance > 0 ? 'var(--red)' : 'var(--accent)';
      return `
        <tr style="border-bottom:1px solid var(--border);">
          <td style="padding:8px 4px; font-family:'DM Mono',monospace; font-size:12px; color:var(--text-dim);">${FY_MONTH_NAMES[i]}</td>
          <td style="padding:8px 4px; font-family:'DM Mono',monospace; font-size:12px; color:var(--text); text-align:right;">${formatCurrency(Math.round(monthlyAmount), userCurrency)}</td>
          <td style="padding:8px 4px; font-family:'DM Mono',monospace; font-size:12px; color:var(--text); text-align:right;">${formatCurrency(Math.round(actual), userCurrency)}</td>
          <td style="padding:8px 4px; font-family:'DM Mono',monospace; font-size:12px; color:${varianceColor}; text-align:right;">${formatCurrency(Math.round(Math.abs(variance)), userCurrency)}</td>
        </tr>`;
    }).join('');

    const tableEl = document.getElementById('catModalTable');
    if (tableEl) {
      tableEl.innerHTML = `
        <thead>
          <tr style="border-bottom:1px solid var(--border);">
            <th style="padding:6px 4px; font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); text-align:left; font-weight:400;">Month</th>
            <th style="padding:6px 4px; font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); text-align:right; font-weight:400;">Budget</th>
            <th style="padding:6px 4px; font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); text-align:right; font-weight:400;">Actual</th>
            <th style="padding:6px 4px; font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); text-align:right; font-weight:400;">Variance</th>
          </tr>
        </thead>
        <tbody>${rowsHtml}</tbody>`;
    }

    // Totals
    const totalBudget  = cat.annualBudget;
    const totalActual  = cat.annualActual;
    const totalRemaining = totalBudget - totalActual;
    const remainColor  = totalRemaining < 0 ? 'var(--red)' : 'var(--accent)';

    const totalsEl = document.getElementById('catModalTotals');
    if (totalsEl) {
      totalsEl.innerHTML = `
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:6px;">Annual Budget</div>
          <div style="font-family:'DM Mono',monospace; font-size:16px; font-weight:500; color:var(--text);">${formatCurrency(Math.round(totalBudget), userCurrency)}</div>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:6px;">Total Spent</div>
          <div style="font-family:'DM Mono',monospace; font-size:16px; font-weight:500; color:var(--text);">${formatCurrency(Math.round(totalActual), userCurrency)}</div>
        </div>
        <div>
          <div style="font-family:'DM Mono',monospace; font-size:10px; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); margin-bottom:6px;">Remaining</div>
          <div style="font-family:'DM Mono',monospace; font-size:16px; font-weight:500; color:${remainColor};">${formatCurrency(Math.round(Math.abs(totalRemaining)), userCurrency)}</div>
        </div>`;
    }

    const nameEl = document.getElementById('catModalName');
    if (nameEl) nameEl.textContent = cat.name;

    const modal = document.getElementById('catModal');
    if (modal) modal.style.display = 'block';
  }

  function closeCatModal(event?: MouseEvent) {
    const modal = document.getElementById('catModal');
    if (!modal) return;
    if (event && event.target !== modal) return;
    modal.style.display = 'none';
  }

  // Make functions available globally
  window.loadYear = loadYear;
  window.updateExchangeRate = updateExchangeRate;
  window.handleSignOut = handleSignOut;
  window.changeFY = changeFY;
  window.toggleTheme = toggleTheme;
  window.openCatModal = openCatModal;
  window.closeCatModal = closeCatModal;
  window.switchChartMode = switchChartMode;
  window.switchAllChartMode = switchAllChartMode;

  // Close modal on Escape key
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') {
      const modal = document.getElementById('catModal');
      if (modal && modal.style.display !== 'none') {
        closeCatModal();
      }
    }
  });

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  /* Page-specific styles for index.astro (yearly overview) */

  /* Override base page width for wider yearly layout */
  html, body {
    background: var(--bg) !important;
    color: var(--text) !important;
  }

  body {
    background: var(--bg) !important;
    padding: 40px 40px;
  }

  .page {
    max-width: 1400px;
    background: var(--bg) !important;
  }

  h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1;
    color: var(--text) !important;
    letter-spacing: -0.02em;
  }

  h1 span {
    color: var(--accent) !important;
  }

  /* Override summary grid columns for wider layout */
  .summary-grid {
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  /* Override summary card to use !important (combats Astro scoping) */
  .summary-card {
    background: var(--surface) !important;
  }

  /* Override balance-section: no bottom margin on year page */
  .balance-section {
    margin-bottom: 0;
  }

  input[type="number"] {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 4px;
    transition: border-color 0.15s;
  }
  input[type="number"]:focus {
    outline: none;
    border-color: var(--accent);
  }

  #categoryBreakdown {
    margin-bottom: 48px;
  }

  #categoriesContainer {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border) !important;
    border: 1px solid var(--border) !important;
    margin-top: 0;
  }

  .cat-card {
    background: var(--surface) !important;
    padding: 20px;
    border: none;
  }

  .cat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .cat-name {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 300;
    font-style: italic;
    color: var(--text-dim) !important;
    letter-spacing: -0.01em;
  }

  .cat-detail-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding: 4px 9px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cat-detail-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .cat-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 10px;
  }

  .cat-row .label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted) !important;
    margin: 0;
  }

  .cat-val {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: var(--text) !important;
    letter-spacing: -0.01em;
  }

  .cat-val.green { color: var(--accent) !important; }
  .cat-val.red { color: var(--red) !important; }

  .cat-progress-track {
    margin-top: 14px;
    height: 4px;
    background: var(--surface2);
    border-radius: 2px;
    overflow: hidden;
  }

  .cat-progress-bar {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .cat-progress-bar.over {
    background: var(--red);
  }

  /* ── Sparklines (inside unified cat-cards) ── */
  .sparkline-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .sparkline-ref {
    stroke: var(--border);
    stroke-width: 1;
    stroke-dasharray: 3 3;
    fill: none;
  }

  .sparkline-line {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .sparkline-dot {
    fill: var(--accent);
    stroke: none;
  }

  .chart-month-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
  }

  .chart-month-labels span {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    text-align: center;
    flex: 1;
  }

  /* ── Sparkline chart mode toggle ── */
  .chart-toggle-row {
    display: flex;
    gap: 4px;
    margin-top: 14px;
  }

  .chart-mode-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    cursor: pointer;
    border-radius: 3px;
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }

  .chart-mode-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .chart-mode-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }

</style>
</html>
