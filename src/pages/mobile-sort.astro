  .results-cat-name  { color: #d8e0d4; font-size: 12px; letter-spacing: 0.05em; margin-bottom: 3px; }
  .results-cat-count { color: #5a6358; font-size: 10px; }

  .results-amount {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 300;
    flex-shrink: 0;
    margin-left: 12px;
  }
  .amount-pos { color: #c8f560; }
  .amount-neg { color: #f56060; }

  .results-empty { color: #5a6358; font-size: 12px; padding: 24px; text-align: center; }

  .uncat-section {
    background: rgba(245,96,96,0.06);
    border: 1px solid rgba(245,96,96,0.2);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .uncat-text { color: #f56060; font-size: 11px; letter-spacing: 0.05em; }

  .results-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .results-back-link {
    color: #5a6358;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.15s;
  }
  .results-back-link:hover { color: #c8f560; }

  /* ══════════════════════════════════════════════════════════════════════════
     ANIMATIONS
     Card slides are driven by inline CSS transitions (see slideCardOut/In).
     Category grid uses keyframe animations for a subtle cross-axis feel.
     ══════════════════════════════════════════════════════════════════════ */
  @keyframes catsEnterForward {
    from { transform: translateX(40px); opacity: 0; }
    to   { transform: translateX(0);    opacity: 1; }
  }
  @keyframes catsEnterBackward {
    from { transform: translateX(-40px); opacity: 0; }
    to   { transform: translateX(0);     opacity: 1; }
  }

  .cats-enter-forward  { animation: catsEnterForward  0.28s cubic-bezier(0.22,1,0.36,1) both; }
  .cats-enter-backward { animation: catsEnterBackward 0.28s cubic-bezier(0.22,1,0.36,1) both; }
</style>

