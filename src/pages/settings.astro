---
// Settings page
import { supabase } from '../lib/supabase';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - Budget Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
<div class="page">

  <header>
    <div class="label">Settings</div>
    <h1>Budget<span> Settings</span></h1>
    <div class="subtitle">Manage categories and preferences</div>
    
    <!-- Navigation -->
    <div style="margin-top: 20px; display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <a href="/" class="currency-btn" style="text-decoration: none; display: inline-block;">← Back to Overview</a>
      <div id="currentUserEmail" style="margin-left: auto; padding: 6px 12px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface2); color: var(--text-dim); font-family: 'DM Mono', monospace; font-size: 11px; max-width: 280px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="Signed in user">Loading account...</div>
      <button class="currency-btn" onclick="handleSignOut()" style="color: var(--red);" title="Sign Out">Sign Out</button>
    </div>
  </header>

  <!-- Currency Settings -->
  <div class="balance-section">
    <div class="label">Currency Settings</div>
    <div style="margin-top: 16px;">
      <div style="margin-bottom: 24px;">
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 8px;">Preferred Currency</label>
        <select id="preferredCurrency" class="balance-input" style="width: 200px;">
          <option value="ZAR">ZAR – South African Rand</option>
          <option value="USD">USD – US Dollar</option>
          <option value="GBP">GBP – British Pound</option>
          <option value="EUR">EUR – Euro</option>
        </select>
        <div style="color: var(--text-dim); font-size: 10px; margin-top: 4px;">This currency will be used throughout the app</div>
      </div>
      
      <div style="margin-bottom: 24px;">
        <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 8px;">
          <input type="checkbox" id="showConversion">
          Show Currency Conversion
        </label>
        <div id="conversionSettings" style="margin-top: 12px; margin-left: 24px; opacity: 0.5;">
          <label style="color: var(--text-dim); font-size: 10px; display: block; margin-bottom: 8px;">Convert to</label>
          <select id="conversionCurrency" class="balance-input" style="width: 200px;">
            <option value="GBP">GBP (British Pound)</option>
            <option value="USD">USD (US Dollar)</option>
            <option value="EUR">EUR (Euro)</option>
            <option value="ZAR">ZAR (South African Rand)</option>
          </select>
        </div>
      </div>
      
      <button class="currency-btn" onclick="saveCurrencySettings()" style="margin-top: 8px;">Save Currency Settings</button>
    </div>
  </div>

  <!-- Category Management -->
  <div class="balance-section">
    <div class="label">Category Management</div>
    <div style="margin-top: 16px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
        <div style="color: var(--text-dim); font-size: 11px;">Manage your budget categories</div>
        <button class="currency-btn" onclick="addNewCategory()" style="font-size: 11px; padding: 6px 12px;">+ Add Category</button>
      </div>
      
      <div id="categoriesList" style="display: flex; flex-direction: column; gap: 8px;">
        <!-- Categories will be loaded here -->
      </div>
    </div>
  </div>

  <footer>Budget Tracker · Settings</footer>

</div>

<button class="theme-toggle" onclick="toggleTheme()" id="themeToggle">☀ Light</button>

<script>
  import { supabase } from '../lib/supabase';
  import { getCurrentUser, onAuthStateChange, signOut } from '../lib/auth';
  import { showToast, showConfirm, showPrompt } from '../lib/dialogs';
  import type { User } from '@supabase/supabase-js';

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    const btn = document.getElementById('themeToggle');
    if (btn) btn.textContent = theme === 'light' ? '☾ Dark' : '☀ Light';
  }

  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }

  // Apply saved theme immediately on load
  const savedTheme = localStorage.getItem('theme') || 'dark';
  applyTheme(savedTheme);

  let categories = [];
  let settings = {};
  let userCurrency = 'ZAR';

  // Check authentication on page load
  async function checkAuth() {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = '/auth';
      return false;
    }
    updateCurrentUserEmail(user);
    return true;
  }

  function updateCurrentUserEmail(user: User | null) {
    const emailEl = document.getElementById('currentUserEmail');
    if (!emailEl) return;
    emailEl.textContent = user?.email || 'Signed in';
    emailEl.title = user?.email || 'Signed in user';
  }

  // Handle sign out
  async function handleSignOut() {
    if (await showConfirm('Sign Out', 'Are you sure you want to sign out?', 'Sign Out')) {
      await signOut();
      window.location.href = '/auth';
    }
  }

  function showSkeletons() {
    const categoriesList = document.getElementById('categoriesList');
    if (categoriesList) {
      categoriesList.innerHTML = `
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
        <div class="skeleton skeleton-row" style="width: 100%;"></div>
      `;
    }
  }

  // Initialize
  async function init() {
    onAuthStateChange((_event, session) => {
      updateCurrentUserEmail(session?.user ?? null);
      if (!session?.user) {
        window.location.href = '/auth';
      }
    });

    showSkeletons();
    const isAuthenticated = await checkAuth();
    if (!isAuthenticated) {
      return;
    }
    
    await loadSettings();
    await loadCategories();
    setupConversionToggle();
  }

  async function loadSettings() {
    try {
      const user = await getCurrentUser();
      if (!user) return;

      const { data: settingsRows } = await supabase
        .from('user_settings')
        .select('key, value, preferred_currency')
        .eq('user_id', user.id);

      const settingsMap = Object.fromEntries((settingsRows || []).map(s => [s.key, s.value]));
      userCurrency = settingsRows?.[0]?.preferred_currency || 'ZAR';
      const showConversion = settingsMap['show_currency_conversion'] === 'true';
      const conversionCurrency = settingsMap['conversion_currency'] || 'GBP';

      // Set UI values
      const preferredCurrencySelect = document.getElementById('preferredCurrency');
      if (preferredCurrencySelect) {
        preferredCurrencySelect.value = userCurrency;
      }

      const showConversionCheckbox = document.getElementById('showConversion');
      if (showConversionCheckbox) {
        showConversionCheckbox.checked = showConversion;
      }

      const conversionCurrencySelect = document.getElementById('conversionCurrency');
      if (conversionCurrencySelect) {
        conversionCurrencySelect.value = conversionCurrency;
      }

      updateConversionSettingsVisibility();
    } catch (error) {
      console.error('Error loading settings:', error);
    }
  }
  
  function updateConversionSettingsVisibility() {
    const checkbox = document.getElementById('showConversion');
    const settingsDiv = document.getElementById('conversionSettings');
    if (checkbox && settingsDiv) {
      settingsDiv.style.opacity = checkbox.checked ? '1' : '0.5';
      settingsDiv.style.pointerEvents = checkbox.checked ? 'auto' : 'none';
    }
  }

  async function loadCategories() {
    try {
      const { data, error } = await supabase
        .from('categories')
        .select('*')
        .order('category_group', { ascending: true, nullsFirst: false })
        .order('type', { ascending: false })
        .order('name', { ascending: true });
      
      if (error) throw error;
      
      categories = data || [];
      renderCategories();
    } catch (error) {
      console.error('Error loading categories:', error);
    }
  }

  function renderCategories() {
    const container = document.getElementById('categoriesList');
    if (!container) return;
    
    if (categories.length === 0) {
      container.innerHTML = '<div style="color: var(--text-dim); padding: 24px; text-align: center;">No categories found. Add your first category above.</div>';
      return;
    }
    
    container.innerHTML = '';
    
    const currencySymbol = getCurrencySymbol(userCurrency);

    categories.forEach(cat => {
      const div = document.createElement('div');
      div.className = 'category-item';
      div.style.cssText = 'display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--surface2); border: 1px solid var(--border); border-radius: 4px;';
      
      div.innerHTML = `
        <div style="flex: 1; display: flex; flex-direction: column; gap: 4px;">
          <input type="text" 
                 value="${escapeHtml(cat.name)}" 
                 data-id="${cat.id}"
                 class="category-name-input"
                 style="background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; padding: 6px 10px; border-radius: 4px; width: 100%;"
                 onchange="updateCategoryName('${cat.id}', this.value)">
          <div style="display: flex; gap: 12px; align-items: center; font-size: 10px; color: var(--text-dim);">
            <span>Type: ${cat.type || 'variable'}</span>
            ${cat.category_group ? `<span>Group: ${escapeHtml(cat.category_group)}</span>` : ''}
          </div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 2px; align-items: flex-end; flex-shrink: 0;">
          <label style="color: var(--text-dim); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;">Default budget</label>
          <div style="display: flex; align-items: center; gap: 4px;">
            <span style="color: var(--muted); font-size: 11px;">${currencySymbol}</span>
            <input type="number"
                   value="${parseFloat(cat.monthly_amount || 0)}"
                   class="category-default-input"
                   style="background: var(--surface); border: 1px solid var(--border); color: var(--text); font-family: 'DM Mono', monospace; font-size: 12px; padding: 6px 10px; border-radius: 4px; width: 100px; text-align: right;"
                   onchange="updateCategoryDefault('${cat.id}', this.value)"
                   onblur="updateCategoryDefault('${cat.id}', this.value)"
                   placeholder="0">
          </div>
        </div>
        <button onclick="deleteCategory('${cat.id}')" 
                style="background: var(--red); border: 1px solid var(--red); color: white; font-family: 'DM Mono', monospace; font-size: 11px; padding: 6px 12px; cursor: pointer; border-radius: 4px; transition: all 0.15s; flex-shrink: 0;"
                onmouseover="this.style.opacity='0.8'"
                onmouseout="this.style.opacity='1'">Delete</button>
      `;
      
      container.appendChild(div);
    });
  }


  async function saveCurrencySettings() {
    try {
      const user = await getCurrentUser();
      if (!user) {
        showToast('You must be logged in to save settings', 'error');
        return;
      }
      
      const preferredCurrency = document.getElementById('preferredCurrency').value;
      const showConversion = document.getElementById('showConversion').checked;
      const conversionCurrency = document.getElementById('conversionCurrency').value;
      
      // Update preferred_currency
      await supabase
        .from('user_settings')
        .upsert({
          user_id: user.id,
          key: 'preferred_currency',
          value: preferredCurrency,
          preferred_currency: preferredCurrency
        }, {
          onConflict: 'user_id,key'
        });
      
      // Update show_currency_conversion
      await supabase
        .from('user_settings')
        .upsert({
          user_id: user.id,
          key: 'show_currency_conversion',
          value: showConversion.toString()
        }, {
          onConflict: 'user_id,key'
        });
      
      // Update conversion_currency
      await supabase
        .from('user_settings')
        .upsert({
          user_id: user.id,
          key: 'conversion_currency',
          value: conversionCurrency
        }, {
          onConflict: 'user_id,key'
        });
      
      showToast('Currency settings saved');
      // Reload page to apply currency changes
      window.location.reload();
    } catch (error) {
      console.error('Error saving currency settings:', error);
      showToast('Error saving currency settings: ' + error.message, 'error');
    }
  }

  async function updateCategoryName(categoryId, newName) {
    if (!newName || newName.trim() === '') {
      showToast('Category name cannot be empty', 'error');
      await loadCategories(); // Reload to reset
      return;
    }
    
    try {
      const { error } = await supabase
        .from('categories')
        .update({ name: newName.trim() })
        .eq('id', categoryId);
      
      if (error) throw error;
      
      // Update local array
      const index = categories.findIndex(c => c.id === categoryId);
      if (index !== -1) {
        categories[index].name = newName.trim();
      }
    } catch (error) {
      console.error('Error updating category name:', error);
      showToast('Error updating category: ' + error.message, 'error');
      await loadCategories(); // Reload on error
    }
  }

  async function updateCategoryDefault(categoryId, value) {
    const amount = parseFloat(value) || 0;
    try {
      const { error } = await supabase
        .from('categories')
        .update({ monthly_amount: amount })
        .eq('id', categoryId);
      
      if (error) throw error;
      
      // Update local array
      const index = categories.findIndex(c => c.id === categoryId);
      if (index !== -1) {
        categories[index].monthly_amount = amount;
      }
    } catch (error) {
      console.error('Error updating category default:', error);
      showToast('Error updating default budget: ' + error.message, 'error');
      await loadCategories(); // Reload on error
    }
  }

  async function addNewCategory() {
    const user = await getCurrentUser();
    if (!user) {
      showToast('You must be logged in to add categories', 'error');
      return;
    }

    const name = await showPrompt('Add Category', 'e.g. Groceries', 'Add');
    if (!name) return;

    const isFixed = await showConfirm('Category Type', 'Is this a fixed monthly expense?', 'Yes, fixed');
    const type = isFixed ? 'fixed' : 'variable';

    try {
      const { data, error } = await supabase
        .from('categories')
        .insert({
          name: name,
          type: type,
          monthly_amount: 0,
          user_id: user.id
        })
        .select()
        .single();

      if (error) throw error;

      showToast(`Category "${name}" added`);
      await loadCategories();
    } catch (error) {
      console.error('Error adding category:', error);
      showToast('Error adding category: ' + error.message, 'error');
    }
  }

  async function deleteCategory(categoryId) {
    const category = categories.find(c => c.id === categoryId);
    if (!category) return;
    
    if (!await showConfirm('Delete Category', `Delete "${category.name}"? This will also delete all associated budgets.`, 'Delete', true)) {
      return;
    }
    
    try {
      const { error } = await supabase
        .from('categories')
        .delete()
        .eq('id', categoryId);
      
      if (error) throw error;
      
      await loadCategories();
    } catch (error) {
      console.error('Error deleting category:', error);
      showToast('Error deleting category: ' + error.message, 'error');
    }
  }

  function getCurrencySymbol(currency) {
    const symbols = {
      'ZAR': 'R',
      'GBP': '£',
      'USD': '$',
      'EUR': '€'
    };
    return symbols[currency] || currency;
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Make functions available globally
  function setupConversionToggle() {
    const checkbox = document.getElementById('showConversion');
    if (checkbox) {
      checkbox.addEventListener('change', updateConversionSettingsVisibility);
    }
  }

  window.updateCategoryName = updateCategoryName;
  window.updateCategoryDefault = updateCategoryDefault;
  window.addNewCategory = addNewCategory;
  window.deleteCategory = deleteCategory;
  window.saveCurrencySettings = saveCurrencySettings;
  window.handleSignOut = handleSignOut;
  window.toggleTheme = toggleTheme;

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  /* Page-specific styles for settings.astro */

  h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  h1 span {
    color: var(--accent);
  }

  select.balance-input {
    cursor: pointer;
  }

  .category-item {
    transition: all 0.15s;
  }

  .category-item:hover {
    border-color: var(--accent) !important;
  }

  .category-name-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .category-default-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    width: 16px;
    height: 16px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    position: relative;
    transition: all 0.15s;
    margin-right: 8px;
    vertical-align: middle;
  }

  input[type="checkbox"]:hover {
    border-color: var(--accent);
  }

  input[type="checkbox"]:checked {
    background: var(--accent);
    border-color: var(--accent);
  }

  input[type="checkbox"]:checked::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #0d0f0e;
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
  }

  input[type="checkbox"]:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(200, 245, 96, 0.2);
  }

</style>
</html>
